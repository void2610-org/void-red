  m_Name: BattleTutorial
  m_EditorClassIdentifier: 
  tutorialId: Battle
  steps:
  - message: "\u305D\u308C\u3067\u306F\u65E9\u901F\u6A21\u64EC\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u3092\u3057\u3066\u3044\u304D\u307E\u3057\u3087\u3046\u304B\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u30DC\u30AF\u304C\u5BFE\u6226\u76F8\u624B\u3060\u3068\u601D\u3063\u3066\u3084\u3063\u3066\u307F\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u2026\u3002"
    isPlayerDialog: 1
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u308F\u304B\u3063\u305F\u3002"
    isPlayerDialog: 1
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3055\u304D\u307B\u3069\u914D\u3089\u308C\u305F\u672D\u306F\u300C\u7CBE\u795E\u672D\u300D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 270, y: -110}
    maskSize: {x: 425, y: 250}
  - message: "\u3053\u308C\u3092\u5DEE\u3057\u51FA\u3059\u3053\u3068\u3067\u3042\u306A\u305F\u306E\u611F\u60C5\u3092\u8CED\u3051\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 270, y: -110}
    maskSize: {x: 425, y: 250}
  - message: "\u4EFB\u610F\u306E\u672D\u3092\u9078\u3076\u3053\u3068\u3067\u305D\u306E\u672D\u306E\u7279\u6027\u3092\u898B\u308B\u3053\u3068\u304C\u3067\u304D\u308B\u306E\u3067\u8FF7\u3063\u305F\u3089\u8AAD\u3093\u3067\u307F\u3066\u304F\u3060\u3055\u3044\u3002\n"
    isPlayerDialog: 0
    maskPosition: {x: 425, y: 90}
    maskSize: {x: 175, y: 65}
  - message: "\u304D\u3063\u3068\u3042\u306A\u305F\u306E\u624B\u52A9\u3051\u306B\u306A\u308B\u3067\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 425, y: 90}
    maskSize: {x: 175, y: 65}
  - message: "\u672D\u3092\u9078\u3093\u3060\u3089\u6B6F\u8ECA\u3092\u56DE\u3057\u3066\u51FA\u3057\u65B9\u3092\u9078\u3093\u3067\u304F\u3060\u3055\u3044\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -390, y: -160}
    maskSize: {x: 250, y: 250}
  - message: "\u3042\u306A\u305F\u306E\u305D\u306E\u6642\u306E\u72B6\u614B\u304C\u7CBE\u795E\u672D\u306B\u30D0\u30A4\u30A2\u30B9\u3092\u304B\u3051\u307E\u3059\u3002\n\u72B6\u6CC1\u306B\u5FDC\u3058\u3066\u9069\u5207\u306A\u51FA\u3057\u65B9\u3092\u9078\u3076\u3068\u3044\u3044\u3067\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -390, y: -160}
    maskSize: {x: 250, y: 250}
  - message: "\u305D\u3053\u306B\u3042\u306A\u305F\u306E\u672C\u97F3\u304C\u5BBF\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -390, y: -160}
    maskSize: {x: 250, y: 250}
  - message: "\u305D\u3057\u3066\u3042\u306A\u305F\u306E\u7CBE\u795E\u5024\u3092\u30D9\u30C3\u30C8\u3059\u308B\u524D\u306B\u6CE8\u610F\u3057\u3066\u3044\u305F\u3060\u304D\u305F\u3044\u306E\u306F\u3053\u306E\u6570\u5024\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -450, y: 150}
    maskSize: {x: 125, y: 250}
  - message: "\u3053\u306E\u6570\u5024\u306F\u3042\u306A\u305F\u3068\u5BFE\u6226\u76F8\u624B\u306E\u7CBE\u795E\u5024\u6B8B\u91CF\u3001\u3053\u3053\u3067\u306F\u3042\u306A\u305F\u3068\u30DC\u30AF\u306E\u3067\u3059\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -450, y: 150}
    maskSize: {x: 125, y: 250}
  - message: "\u3053\u306E\u6570\u5024\u304C0\u306B\u306A\u3063\u3066\u3057\u307E\u3046\u3068\u3042\u306A\u305F\u306E\u7CBE\u795E\u529B\u306F\u6D88\u3048\u3001\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u306B\u53C2\u52A0\u3057\u7D9A\u3051\u308B\u306E\u304C\u56F0\u96E3\u306B\u306A\u3063\u3066\u3057\u307E\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -450, y: 150}
    maskSize: {x: 125, y: 250}
  - message: "\u3053\u3053\u306B\u73FE\u5728\u306E\u30D9\u30C3\u30C8\u5024\u304C\u8868\u793A\u3055\u308C\u3066\u3044\u308B\u306E\u3067\u81EA\u5206\u306E\u899A\u609F\u306E\u5206\u3060\u3051\u7CBE\u795E\u5024\u3092\u8CED\u3051\u3066\u3044\u304D\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 385, y: -200}
    maskSize: {x: 250, y: 175}
  - message: "\u3053\u3053\u306B\u3069\u308C\u3060\u3051\u6CE8\u304E\u8FBC\u3081\u308B\u304B\u304C\u3042\u306A\u305F\u306E\u904B\u547D\u3092\u308F\u3051\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 385, y: -200}
    maskSize: {x: 250, y: 175}
  - message: "\u3057\u304B\u3057\u672D\u306F\u8106\u304F\u3001\u3042\u307E\u308A\u6CE8\u304E\u8FBC\u307F\u3059\u304E\u308B\u3068\u300C\u5D29\u58CA\u300D\u306E\u6050\u308C\u304C\u3042\u308B\u306E\u3067\u30D9\u30C3\u30C8\u3059\u308B\u3068\u304D\u306F\u3088\u308A\u614E\u91CD\u306B\u884C\u3063\u3066\u304F\u3060\u3055\u3044\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 385, y: -200}
    maskSize: {x: 250, y: 175}
  - message: "\u3053\u306E\u90E8\u5206\u306B\u306F\u305D\u306E\u30BF\u30FC\u30F3\u306E\u5546\u54C1\u30C6\u30FC\u30DE\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 260}
    maskSize: {x: 475, y: 60}
  - message: "\u3042\u306A\u305F\u306E\u9078\u629E\u304C\u30C6\u30FC\u30DE\u306B\u3069\u308C\u3060\u3051\u5408\u81F4\u3059\u308B\u304B\u3067\u3001\u6700\u7D42\u30D9\u30C3\u30C8\u30B9\u30B3\u30A2\u304C\u6C7A\u307E\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 260}
    maskSize: {x: 475, y: 60}
  - message: "\u3053\u306E\u6700\u7D42\u30B9\u30B3\u30A2\u304C\u9AD8\u3044\u307B\u3046\u304C\u52DD\u5229\u3057\u3001\u5546\u54C1\u30C6\u30FC\u30DE\u3068\u306A\u3063\u305F\u8A18\u61B6\u3092\u7372\u5F97\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 260}
    maskSize: {x: 475, y: 60}
  - message: "\u4EE5\u4E0A\u3067\u3001\u8AAC\u660E\u306F\u7D42\u4E86\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u65E9\u901F\u672D\u3092\u4F7F\u3063\u3066\u6226\u3063\u3066\u307F\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
