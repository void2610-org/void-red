  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: BattleTutorial
  m_EditorClassIdentifier: 
  steps:
  - message: "\u3053\u306E\u30B2\u30FC\u30E0\u306E\u57FA\u672C\u7684\u306A\u904A\u3073\u65B9\u3092\u8AAC\u660E\u3057\u307E\u3059"
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u306E\u90E8\u5206\u306B\u306F\u300C\u7CBE\u795E\u672D\u300D\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
    maskPosition: {x: 250, y: -125}
    maskSize: {x: 500, y: 250}
  - message: "\u3053\u306E\u90E8\u5206\u3092\u30AF\u30EA\u30C3\u30AF\u3057\u3066\u30AB\u30FC\u30C9\u306E\u51FA\u3057\u65B9\u3092\u9078\u629E\u3057\u307E\u3059\u3002"
    maskPosition: {x: -410, y: -175}
    maskSize: {x: 250, y: 250}
  - message: "\u3053\u306E\u90E8\u5206\u306B\u306F\u3042\u306A\u305F\u3068\u5BFE\u6226\u76F8\u624B\u306E\u6B8B\u308A\u7CBE\u795E\u529B\u304C\u8868\u793A\u3055\u308C\u3066\u3044\u307E\u3059\u3002"
    maskPosition: {x: -460, y: 150}
    maskSize: {x: 125, y: 250}
  - message: "+ / - \u306E\u30DC\u30BF\u30F3\u3092\u30AF\u30EA\u30C3\u30AF\u3057\u3066\u3001\u30D9\u30C3\u30C8\u3059\u308B\u7CBE\u795E\u529B\u306E\u91CF\u3092\u9078\u629E\u3057\u307E\u3059\u3002"
    maskPosition: {x: 400, y: -215}
    maskSize: {x: 250, y: 150}
  - message: "\u591A\u304F\u306E\u7CBE\u795E\u529B\u3092\u30D9\u30C3\u30C8\u3059\u308B\u307B\u3069\u30B9\u30B3\u30A2\u304C\u5897\u52A0\u3057\u307E\u3059\u304C\u3001\u30AB\u30FC\u30C9\u304C\u300C\u5D29\u58CA\u300D\u3059\u308B\u30EA\u30B9\u30AF\u3082\u9AD8\u307E\u308A\u307E\u3059\u3002"
    maskPosition: {x: 400, y: -215}
    maskSize: {x: 250, y: 150}
  - message: "\u3053\u306E\u90E8\u5206\u306B\u306F\u300C\u30C6\u30FC\u30DE\u300D\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
    maskPosition: {x: 0, y: 260}
    maskSize: {x: 450, y: 75}
  - message: "\u304A\u4E92\u3044\u306E\u884C\u52D5\u306F\u30C6\u30FC\u30DE\u3068\u306E\u9069\u5408\u5EA6\u3067\u30B9\u30B3\u30A2\u5316\u3055\u308C\u3001\u3088\u308A\u9AD8\u3044\u30B9\u30B3\u30A2\u306E\u65B9\u304C\u305D\u306E\u30BF\u30FC\u30F3\u3092\u52DD\u5229\u3057\u307E\u3059\u3002"
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u5148\u306B3\u30BF\u30FC\u30F3\u52DD\u5229\u3057\u305F\u65B9\u304C\u52DD\u3061\u3067\u3059\u3002"
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u300C\u4EBA\u683C\u30ED\u30B0\u300D\u3067\u306F\u3053\u308C\u307E\u3067\u306E\u884C\u52D5\u5C65\u6B74\u3092\u78BA\u8A8D\u3067\u304D\u307E\u3059\u3002"
    maskPosition: {x: 340, y: 250}
    maskSize: {x: 160, y: 65}
