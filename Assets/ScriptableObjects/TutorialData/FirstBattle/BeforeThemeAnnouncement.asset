  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: BeforeThemeAnnouncement
  m_EditorClassIdentifier: Assembly-CSharp::TutorialData
  steps:
  - message: "\u3053\u3053\u304B\u3089\u306F\u3001\u3053\u306E\u4E16\u754C\u3067\u306E\u30EB\u30FC\u30EB\u3092\u6559\u3048\u3066\u3055\u3057\u3042\u3052\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u307E\u305A\u306F\u3001\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u30D1\u30FC\u30C8\u3067\u3059\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u3053\u306B\u4E26\u3093\u3067\u3044\u308B\u306E\u306F\u3001\u8A18\u61B6\u30AB\u30FC\u30C9\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -220, y: -50}
    maskSize: {x: 580, y: 400}
  - message: "\u3053\u306E\u4E16\u754C\u3067\u306F\u3001\u8A18\u61B6\u306F\u65AD\u7247\u5316\u3057\u3001\u3053\u3046\u3057\u3066\u30AB\u30FC\u30C9\u3068\u3057\u3066\u73FE\u308C\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -220, y: -50}
    maskSize: {x: 580, y: 400}
  - message: "\u30AB\u30FC\u30C9\u306B\u306F\u3001\u81EA\u5DF1\u8A18\u61B6\u3068\u4ED6\u8005\u8A18\u61B6\u304C\u3042\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u81EA\u5DF1\u8A18\u61B6\u306F\u3042\u306A\u305F\u81EA\u8EAB\u306E\u3082\u306E\u3002\u3042\u306A\u305F\u306B\u3068\u3063\u3066\u3001\u304D\u3063\u3068\u5927\u5207\u306A\u8A18\u61B6\u306A\u3093\u3067\u3057\u3087\u3046\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -415, y: 45}
    maskSize: {x: 145, y: 190}
  - message: "\u4ED6\u8005\u8A18\u61B6\u306F\u3001\u3042\u306A\u305F\u4EE5\u5916\u306E\u8AB0\u304B\u304C\u62B1\u3048\u3066\u3044\u305F\u8A18\u61B6\u3067\u3059\u3002\u3042\u306A\u305F\u304C\u305D\u306E\u4EBA\u306B\u3064\u3044\u3066\u77E5\u308A\u305F\u304F\u306A\u3063\u305F\u6642\u3001\u9078\u3093\u3067\u307F\u308B\u3068\u3044\u3044\u3067\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -225, y: -150}
    maskSize: {x: 145, y: 190}
  - message: "\u3053\u306E\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u306B\u306F\u3001\u53C2\u52A0\u8005\u306B\u8AB2\u3055\u308C\u305F\u8A18\u61B6\u30C6\u30FC\u30DE\u304C\u3042\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 250}
    maskSize: {x: 500, y: 115}
  - message: "\u30C6\u30FC\u30DE\u3068\u306F\u3001\u3053\u306E\u968E\u5C64\u3067\u3042\u306A\u305F\u304C\u5411\u304D\u5408\u3046\u3079\u304D\u547D\u984C\u306E\u3088\u3046\u306A\u3082\u306E\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 250}
    maskSize: {x: 500, y: 115}
  - message: "\u307E\u305F\u3001\u8A18\u61B6\u30AB\u30FC\u30C9\u306B\u306F\u611F\u60C5\u5C5E\u6027\u3068\u3044\u3046\u3082\u306E\u304C\u3064\u3044\u3066\u3044\u307E\u3057\u3066\u2026\u2026\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u30AB\u30FC\u30C9\u306E\u3069\u3053\u304B\u306B\u5C5E\u6027\u3054\u3068\u306E\u5370\u304C\u96A0\u308C\u3066\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u4ECA\u56DE\u306F\u3042\u306A\u305F\u304C\u8FF7\u308F\u306A\u3044\u3088\u3046\u306B\u5370\u306E\u5834\u6240\u3092\u5206\u304B\u308A\u3084\u3059\u304F\u3057\u3066\u304A\u304D\u307E\u3057\u305F\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -395.8, y: 33}
    maskSize: {x: 25, y: 25}
  - message: "\u3053\u306E\u5370\u304C\u793A\u3059\u611F\u60C5\u304C\u3001\u305D\u306E\u30AB\u30FC\u30C9\u306E\u611F\u60C5\u5C5E\u6027\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -395.8, y: 33}
    maskSize: {x: 25, y: 25}
  - message: "\u3053\u306E\u5370\u306F\u559C\u3073\u3092\u793A\u3057\u307E\u3059\u3002\u5C5E\u6027\u306E\u5370\u306F\u3044\u3064\u3067\u3082\u78BA\u8A8D\u3067\u304D\u308B\u3088\u3046\u306B\u3057\u3066\u304A\u304D\u307E\u3059\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -490, y: 280}
    maskSize: {x: 70, y: 70}
  - message: "\u5C5E\u6027\u306F\u3001\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u5F8C\u306B\u5F97\u3089\u308C\u308B\u611F\u60C5\u30EA\u30BD\u30FC\u30B9\u306E\u91CF\u306B\u5F71\u97FF\u3057\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -395.8, y: 33}
    maskSize: {x: 25, y: 25}
