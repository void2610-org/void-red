    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u305D\u308C\u306F\u826F\u304B\u3063\u305F\u3067\u3059\u3002\u611F\u60C5\u306E\u30EA\u30BD\u30FC\u30B9\u91CF\u304C\u3042\u306A\u305F\u306E\u601D\u8003\u306B\u591A\u5927\u306A\u5F71\u97FF\u3092\u4E0E\u3048\u308B\u306E\u3067\u7BA1\u7406\u306F\u3057\u3063\u304B\u308A\u3057\u3066\u304F\u3060\u3055\u3044\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u4ECA\u306E\u6240\u305D\u3093\u306A\u306B\u5927\u304D\u306A\u5909\u5316\u304C\u3042\u308B\u3068\u306F\u601D\u3048\u306A\u3044\u3051\u3069...\u3002"
    isPlayerDialog: 1
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u5F8C\u3005\u306B\u308F\u304B\u308A\u307E\u3059\u3088\u3002\u7279\u306B\u6B21\u306E\u30D0\u30C8\u30EB\u3067\u306F\u3068\u3066\u3082\u91CD\u8981\u306B\u306A\u3063\u3066\u304F\u308B\u3067\u3057\u3087\u3046\u3002"
