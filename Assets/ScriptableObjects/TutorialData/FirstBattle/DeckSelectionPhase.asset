  - message: "\u4ECA\u56DE\u306F1\u679A\u3057\u304B\u7372\u5F97\u3067\u304D\u306A\u304B\u3063\u305F\u305F\u3081\u4E88\u5099\u306E\u30AB\u30FC\u30C9\u304C2\u679A\u8FFD\u52A0\u3055\u308C\u307E\u3059\u3002"
