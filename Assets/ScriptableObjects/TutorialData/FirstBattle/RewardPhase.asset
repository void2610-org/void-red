  steps:
  - message: "\u3093\u30FC\u3002\u3042\u307E\u308A\u8A18\u61B6\u3092\u7372\u5F97\u3057\u305F\u5B9F\u611F\u306F\u306A\u3044\u3051\u308C\u3069\u3002"
    isPlayerDialog: 1
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u307E\u3060\u3001\u5B8C\u5168\u306B\u7372\u5F97\u3067\u304D\u305F\u308F\u3051\u3067\u306F\u3042\u308A\u307E\u305B\u3093\u3088\u3002\u3042\u304F\u307E\u3067\u6B21\u306E\u30D0\u30C8\u30EB\u3067\u306E\u624B\u6570\u306E\u4E00\u3064\u306B\u904E\u304E\u307E\u305B\u3093\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u3061\u3089\u304C\u3001\u4ECA\u56DE\u3042\u306A\u305F\u304C\u7372\u5F97\u3057\u305F\u8A18\u61B6\u30AB\u30FC\u30C9\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 1000, y: 400}
  - message: "\u30AB\u30FC\u30C9\u306E\u5C5E\u6027\u3068\u3001\u3042\u306A\u305F\u304C\u30D9\u30C3\u30C8\u3057\u305F\u611F\u60C5\u30EA\u30BD\u30FC\u30B9\u304C\u4E00\u81F4\u3057\u3066\u3044\u305F\u305F\u3081\u3001\u3000\u30C1\u30C3\u30D7\u306E\u7372\u5F97\u91CF\u304C1.5\u500D\u306B\u306A\u3063\u3066\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -275, y: -140}
    maskSize: {x: 400, y: 100}
  - message: "\u3053\u306E\u30AB\u30FC\u30C9\u306F\u81EA\u5DF1\u8A18\u61B6\u3067\u3059\u3002\u3000\u81EA\u5DF1\u8A18\u61B6\u306E\u5834\u5408\u3001\u5BFE\u5FDC\u3059\u308B\u611F\u60C5\u30EA\u30BD\u30FC\u30B9\u304C2\u500D\u3067\u4ED8\u4E0E\u3055\u308C\u307E\u3059\u3002"
