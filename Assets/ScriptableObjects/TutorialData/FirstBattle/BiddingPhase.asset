  steps:
  - message: "\u3055\u3066\u3001\u3053\u3053\u304B\u3089\u306F\u3042\u306A\u305F\u306F\u5165\u672D\u8005\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u673A\u4E0A\u306E8\u679A\u306E\u8A18\u61B6\u30AB\u30FC\u30C9\u306B\u5BFE\u3057\u3066\u5165\u672D\u3092\u3057\u3066\u3044\u305F\u3060\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: -15}
    maskSize: {x: 660, y: 400}
  - message: "\u3053\u3061\u3089\u306E\u6B6F\u8ECA\u306B\u306F\u3042\u306A\u305F\u306E\u4E2D\u306B\u5B58\u5728\u3059\u308B8\u7A2E\u985E\u306E\u611F\u60C5\u3092\u6570\u5024\u5316\u3057\u305F\u30A8\u30CD\u30EB\u30AE\u30FC\u30EA\u30BD\u30FC\u30B9\u304C\u3042\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 430, y: -15}
    maskSize: {x: 220, y: 350}
  - message: "\u3053\u3053\u3067\u306F\u3053\u306E\u611F\u60C5\u304C\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u3067\u306E\u901A\u8CA8\u306B\u5024\u3057\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 430, y: -15}
    maskSize: {x: 220, y: 350}
  - message: "\u6B32\u3057\u3044\u30AB\u30FC\u30C9\u3092\u9078\u3093\u3067\u611F\u60C5\u3092\u5165\u672D\u3057\u3066\u307F\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 430, y: -15}
    maskSize: {x: 220, y: 350}
  - message: "\u3042\u306A\u305F\u306F\u305D\u306E\u8A18\u61B6\u306B\u4F55\u3092\u898B\u51FA\u3057\u307E\u3059\u304B?"
    isPlayerDialog: 0
    maskPosition: {x: 430, y: -15}
    maskSize: {x: 220, y: 350}
  - message: "\u3042\u306A\u305F\u306F\u304B\u3064\u3066\u306E\u81EA\u5206\u3068\u540C\u3058\u9078\u629E\u3092\u3059\u308B\u306E\u304B\u3001\u306F\u305F\u307E\u305F\u5225\u306E\u904B\u547D\u3092\u9078\u3076\u3053\u3068\u304C\u3067\u304D\u308B\u306E\u304B\u3001\u305D\u308C\u3092\u773A\u3081\u308B\u306E\u306F\u3068\u3066\u3082\u6109\u5FEB\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 430, y: -15}
