  tutorialId: Battle6
  steps:
  - message: "\u5408\u81F4\u30AD\u30FC\u30EF\u30FC\u30C9\u6570\u3001\u5C5E\u6027\u5408\u81F4\u5EA6\u3001\u51FA\u3057\u65B9\u76F8\u6027\u3001\n\u7CBE\u795E\u30D9\u30C3\u30C8\u5024\u304B\u3089\u6700\u7D42\u30B9\u30B3\u30A2\u304C\u6C7A\u307E\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u306E\u6700\u7D42\u30B9\u30B3\u30A2\u304C\u9AD8\u3044\u307B\u3046\u304C\u52DD\u5229\u3057\u3001\n\u5546\u54C1\u30C6\u30FC\u30DE\u3068\u306A\u3063\u305F\u8A18\u61B6\u3092\u7372\u5F97\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u6700\u5F8C\u306B\u3001\u3053\u3061\u3089\u306E\u30DC\u30BF\u30F3\u304B\u3089\n\u5B9F\u969B\u306B\u7CBE\u795E\u672D\u3092\u51FA\u3059\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 435, y: 30}
    maskSize: {x: 160, y: 55}
  - message: "\u4EE5\u4E0A\u3067\u3001\u8AAC\u660E\u306F\u7D42\u4E86\u3067\u3059\u3002\n\u65E9\u901F\u672D\u3092\u4F7F\u3063\u3066\u6226\u3063\u3066\u307F\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
