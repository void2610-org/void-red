  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: SpecialMemoryCards
  m_EditorClassIdentifier: 
  steps:
  - message: "\u3053\u3061\u3089\u306E\u8A18\u61B6\u306F\u4ED6\u8005\u8A18\u61B6\u3067\u3042\u308B\u304C\u5C11\u3057\u7279\u6B8A\u306A\u8A18\u61B6\u306B\u306A\u3063\u3066\u304A\u308A\u307E\u3059\u3002\n\"\u7279\u5B9A\u4ED6\u8005\u8A18\u61B6\"\u3068\u3067\u3082\u547C\u3073\u307E\u3057\u3087\u3046\u304B\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 125, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u3053\u306E\u8A18\u61B6\u306F\u304B\u3064\u3066\u306E\u81EA\u5206\u304C\u6C42\u3081\u3066\u3044\u305F\u7B54\u3048\u306B\u306A\u308A\u3046\u308B\u8A18\u61B6\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 125, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u771F\u5B9F\u306E\u4EE3\u511F\u3067\u3042\u308B\u75DB\u307F\u306B\u5BFE\u3057\u3066\u3053\u306E\u8A18\u61B6\u306F\u75DB\u307F\u3092\u548C\u3089\u3052\u308B\u93AE\u75DB\u5264\u306E\u3088\u3046\u306A\u3082\u306E\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 125, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u3053\u306E\u8A18\u61B6\u306F\u3068\u3066\u3082\u5E0C\u5C11\u306A\u70BA\u75DB\u307F\u3067\u82E6\u3057\u3080\u524D\u306B\u7372\u5F97\u3059\u308B\u3053\u3068\u3092\u304A\u3059\u3059\u3081\u3057\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 125, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u305D\u3057\u3066\u6700\u5F8C\u306B\u3053\u306E\"\u66D6\u6627\u8A18\u61B6\"\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 365, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u6B63\u76F4\u30DC\u30AF\u306B\u3082\u3053\u306E\u5B9F\u614B\u304C\u308F\u304B\u3089\u306A\u3044\u306E\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 365, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u5206\u304B\u3063\u3066\u3044\u308B\u306E\u306F\u9577\u3044VOID RED\u306E\u6B74\u53F2\u306E\u4E2D\u3067\u304B\u3064\u3066\u306E\u5BA2\u4EBA\u304C\u6B8B\u3057\u305F\u3082\u306E\u3068\u3044\u3046\u3053\u3068\u3060\u3051\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 365, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u3053\u306E\u8A18\u61B6\u306F\u7A00\u306B\u5B58\u5728\u3092\u73FE\u3057\u3001\u53C2\u52A0\u8005\u306E\u6551\u3044\u3068\u306A\u308B\u306A\u3093\u3066\u5642\u304C\u3042\u308A\u307E\u3059\u304C..."
    isPlayerDialog: 0
    maskPosition: {x: 365, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u6B63\u76F4\u53C2\u52A0\u8005\u306E\u82E6\u3057\u3080\u59FF\u304C\u597D\u304D\u306A\u30DC\u30AF\u306B\u3068\u3063\u3066\u306F\u9762\u767D\u304F\u306A\u3044\u5B58\u5728\u3067\u3059\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 365, y: 0}
    maskSize: {x: 250, y: 350}
