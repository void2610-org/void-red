  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: ThemeAndGauges
  m_EditorClassIdentifier: 
  steps:
  - message: "\u4EE5\u4E0A\u3067\u8A18\u61B6\u30AB\u30FC\u30C9\u306E\u8AAC\u660E\u306F\u7D42\u308F\u308A\u3067\u3059\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u305D\u308C\u3067\u306F\u3053\u308C\u3089\u306E\u30AB\u30FC\u30C9\u3092\u843D\u672D\u5E0C\u671B\u9806\u306B\u4E26\u3079\u3066\u3044\u305F\u3060\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u305D\u306E\u969B\u3053\u3061\u3089\u306E\"\u8A18\u61B6\u30C6\u30FC\u30DE\"\u3001\u305D\u3057\u3066\"\u75DB\u307F\u30B2\u30FC\u30B8\"\u3068\"\u5E0C\u8584\u5316\u30B2\u30FC\u30B8\"\u3092\u53C2\u8003\u306B\u3057\u3066\u3044\u305F\u3060\u3051\u308C\u3070\u3068\u601D\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u8A18\u61B6\u30C6\u30FC\u30DE\u306F\u3044\u308F\u3070\u53C2\u52A0\u8005\u306B\u5BFE\u3059\u308B\u554F\u3044\u306E\u3088\u3046\u306A\u3082\u306E\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u306E\u554F\u3044\u306F\u53C2\u52A0\u8005\u306B\u5171\u901A\u3059\u308B\u304B\u3064\u3066\u306E\"\u5F8C\u6094\"\u3001\u305D\u3057\u3066\"\u9858\u3044\"\u304C\"\u3082\u3068\"\u3068\u306A\u3063\u3066\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u8A18\u61B6\u3092\u5931\u3063\u305F\u3042\u306A\u305F\u306F\u6539\u3081\u3066\u3053\u306E\u8A18\u61B6\u30C6\u30FC\u30DE\u306B\u5BFE\u3057\u3066\u4F55\u3092\u601D\u3046\u306E\u3067\u3057\u3087\u3046\u304B\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3068\u3066\u3082\u8208\u5473\u6DF1\u3044\u3067\u3059\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u305D\u3057\u3066\u3053\u3061\u3089\u306F\u4E0A\u306E\u8D64\u3044\u30B2\u30FC\u30B8\u304C\u75DB\u307F\u3001\u4E0B\u306E\u9752\u3044\u30B2\u30FC\u30B8\u304C\u5E0C\u8584\u5316\u3092\u53EF\u8996\u5316\u3057\u305F\u3082\u306E\u306B\u306A\u3063\u3066\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u308C\u3089\u306E\u30B2\u30FC\u30B8\u304C\u5897\u3048\u308B\u306B\u3064\u308C\u3042\u306A\u305F\u306E\u72B6\u614B\u306F\u6DF1\u523B\u5316\u3057\u3066\u3044\u304D\u6700\u7D42\u7684\u306B\u306F\u3042\u306A\u305F\u81EA\u8EAB\u306E\u8A00\u8449\u306F\u6D88\u3048\u3066\u3057\u307E\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u308C\u3089\u306B\u6C17\u3092\u3064\u3051\u3066\u4E26\u3079\u3066\u307F\u3066\u304F\u3060\u3055\u3044\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
