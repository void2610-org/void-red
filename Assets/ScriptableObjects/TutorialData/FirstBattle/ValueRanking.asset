  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: ValueRanking
  m_EditorClassIdentifier: 
  steps:
  - message: "\u6700\u521D\u306B\u3042\u306A\u305F\u306B\u306F\u624B\u5143\u306B\u7528\u610F\u3055\u308C\u305F\u8A18\u61B6\u30AB\u30FC\u30C9\u3092\u51FA\u54C1\u3057\u3066\u3044\u305F\u3060\u304D\u307E\u3059\u3002"
    isPlayerDialog: 1
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u3061\u3089\u304C\u4ECA\u56DE\u7528\u610F\u3057\u305F\u8A18\u61B6\u30AB\u30FC\u30C9\u3067\u3059\u3002"
    isPlayerDialog: 1
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 1000, y: 350}
  - message: "\u3053\u3061\u3089\u306E\u8A18\u61B6\u306F\u304B\u3064\u3066\u3042\u306A\u305F\u304C\u6240\u6709\u3057\u3066\u3044\u305F\u201D\u81EA\u5DF1\u8A18\u61B6\u201D\u3002"
    isPlayerDialog: 1
    maskPosition: {x: -365, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u3042\u306A\u305F\u304C\u3042\u306A\u305F\u81EA\u8EAB\u306E\u6B63\u4F53\u3092\u53D6\u308A\u623B\u3059\u70BA\u306B\u306F\u5FC5\u8981\u306A\u8A18\u61B6\u306B\u306A\u308A\u307E\u3059\u3002"
    isPlayerDialog: 1
    maskPosition: {x: -365, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u3057\u304B\u3057\u771F\u5B9F\u3092\u77E5\u308B\u3068\u3044\u3046\u306E\u306B\u306F\u75DB\u307F\u304C\u4F34\u3044\u307E\u3059\u3002"
    isPlayerDialog: 1
    maskPosition: {x: -365, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u771F\u5B9F\u3092\u6442\u53D6\u3057\u3059\u304E\u305F\u3042\u306A\u305F\u306F\u767A\u8A71\u3059\u308B\u3053\u3068\u304C\u56F0\u96E3\u306B\u306A\u308B\u3067\u3057\u3087\u3046\u3002"
    isPlayerDialog: 1
    maskPosition: {x: -365, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u3053\u3061\u3089\u306E\u8A18\u61B6\u306F\u3042\u306A\u305F\u3068\u5BFE\u9762\u3057\u3066\u3044\u308B\u4EBA\u7269\u304C\u6240\u6709\u3057\u3066\u3044\u305F\u201D\u4ED6\u8005\u8A18\u61B6\u201D\u3002\n\u3053\u306E\u5834\u5408\u30DC\u30AF\u304C\u6240\u6709\u3057\u3066\u3044\u305F\u8A18\u61B6\u3067\u3059\u306D\u3002\n"
    isPlayerDialog: 1
    maskPosition: {x: -125, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u3042\u306A\u305F\u304C\u3082\u3057\u4ECA\u307E\u3067\u3068\u306F\u9055\u3046\u81EA\u5206\u306B\u306A\u308A\u305F\u3044\u306A\u3089\n\u3053\u306E\u8A18\u61B6\u306F\u5F79\u306B\u7ACB\u3064\u3053\u3068\u3067\u3057\u3087\u3046\u3002 "
    isPlayerDialog: 1
    maskPosition: {x: -125, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u3057\u304B\u3057\u4ED6\u8005\u306B\u89E6\u308C\u3059\u304E\u305F\u3042\u306A\u305F\u306E\u610F\u8B58\u306F\u5E0C\u8584\u5316\u3057\u3001\n\u305D\u3053\u306B\u3042\u306A\u305F\u306E\u610F\u601D\u306F\u5B58\u5728\u3057\u306A\u304F\u306A\u308A\u307E\u3059\u3002"
    isPlayerDialog: 1
    maskPosition: {x: -125, y: 0}
    maskSize: {x: 250, y: 350}
  - message: "\u305D\u306E\u5834\u5408\u3042\u306A\u305F\u306F\u81EA\u5206\u81EA\u8EAB\u3092\u305F\u3060\u508D\u89B3\u3059\u308B\u3053\u3068\u3057\u304B\n\u3067\u304D\u306A\u304F\u306A\u308B\u3067\u3057\u3087\u3046\u3002\n"
    isPlayerDialog: 1
    maskPosition: {x: -125, y: 0}
    maskSize: {x: 250, y: 350}
