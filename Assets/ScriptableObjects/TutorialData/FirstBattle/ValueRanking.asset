  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: ValueRanking
  m_EditorClassIdentifier: 
  steps:
  - message: "\u6700\u521D\u306B\u3042\u306A\u305F\u306B\u306F\u624B\u5143\u306B\u7528\u610F\u3055\u308C\u305F\u8A18\u61B6\u30AB\u30FC\u30C9\u3092\u51FA\u54C1\u3057\u3066\u3044\u305F\u3060\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u3061\u3089\u304C\u4ECA\u56DE\u7528\u610F\u3057\u305F\u8A18\u61B6\u30AB\u30FC\u30C9\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: -185}
    maskSize: {x: 600, y: 230}
  - message: "\u8A18\u61B6\u30AB\u30FC\u30C9\u306F\u305D\u306E\u7279\u6027\u304B\u30894\u7A2E\u985E\u306B\u5927\u5225\u3055\u308C\u307E\u3059\u3002\n\u4ECA\u56DE\u306F1\u679A\u305A\u3064\u7528\u610F\u3057\u307E\u3057\u305F\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: -185}
    maskSize: {x: 600, y: 230}
  - message: "\u3053\u3061\u3089\u306E\u8A18\u61B6\u306F\u304B\u3064\u3066\u3042\u306A\u305F\u304C\u6240\u6709\u3057\u3066\u3044\u305F\u201D\u81EA\u5DF1\u8A18\u61B6\u201D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -185, y: -195}
    maskSize: {x: 155, y: 210}
  - message: "\u3042\u306A\u305F\u304C\u3042\u306A\u305F\u81EA\u8EAB\u306E\u6B63\u4F53\u3092\u53D6\u308A\u623B\u3059\u70BA\u306B\u306F\u5FC5\u8981\u306A\u8A18\u61B6\u306B\u306A\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -185, y: -195}
    maskSize: {x: 155, y: 210}
  - message: "\u3057\u304B\u3057\u771F\u5B9F\u3092\u77E5\u308B\u3068\u3044\u3046\u306E\u306B\u306F\u75DB\u307F\u304C\u4F34\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -185, y: -195}
    maskSize: {x: 155, y: 210}
  - message: "\u771F\u5B9F\u3092\u6442\u53D6\u3057\u3059\u304E\u305F\u3042\u306A\u305F\u306F\u767A\u8A71\u3059\u308B\u3053\u3068\u304C\u56F0\u96E3\u306B\u306A\u308B\u3067\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -185, y: -195}
    maskSize: {x: 155, y: 210}
  - message: "\u3053\u3061\u3089\u306E\u8A18\u61B6\u306F\u3042\u306A\u305F\u3068\u5BFE\u9762\u3057\u3066\u3044\u308B\u4EBA\u7269\u304C\u6240\u6709\u3057\u3066\u3044\u305F\u201D\u4ED6\u8005\u8A18\u61B6\u201D\u3002\n\u3053\u306E\u5834\u5408\u30DC\u30AF\u304C\u6240\u6709\u3057\u3066\u3044\u305F\u8A18\u61B6\u3067\u3059\u306D\u3002\n"
    isPlayerDialog: 0
    maskPosition: {x: -65, y: -185}
    maskSize: {x: 155, y: 210}
  - message: "\u3042\u306A\u305F\u304C\u3082\u3057\u4ECA\u307E\u3067\u3068\u306F\u9055\u3046\u81EA\u5206\u306B\u306A\u308A\u305F\u3044\u306A\u3089\n\u3053\u306E\u8A18\u61B6\u306F\u5F79\u306B\u7ACB\u3064\u3053\u3068\u3067\u3057\u3087\u3046\u3002 "
    isPlayerDialog: 0
    maskPosition: {x: -65, y: -185}
    maskSize: {x: 155, y: 210}
  - message: "\u3057\u304B\u3057\u4ED6\u8005\u306B\u89E6\u308C\u3059\u304E\u305F\u3042\u306A\u305F\u306E\u610F\u8B58\u306F\u5E0C\u8584\u5316\u3057\u3001\n\u305D\u3053\u306B\u3042\u306A\u305F\u306E\u610F\u601D\u306F\u5B58\u5728\u3057\u306A\u304F\u306A\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -65, y: -185}
    maskSize: {x: 155, y: 210}
  - message: "\u305D\u306E\u5834\u5408\u3042\u306A\u305F\u306F\u81EA\u5206\u81EA\u8EAB\u3092\u305F\u3060\u508D\u89B3\u3059\u308B\u3053\u3068\u3057\u304B\n\u3067\u304D\u306A\u304F\u306A\u308B\u3067\u3057\u3087\u3046\u3002\n"
    isPlayerDialog: 0
    maskPosition: {x: -65, y: -185}
    maskSize: {x: 155, y: 210}
  - message: "\u3053\u3061\u3089\u306E\u8A18\u61B6\u306F\u4ED6\u8005\u8A18\u61B6\u3067\u3042\u308B\u304C\u5C11\u3057\u7279\u6B8A\u306A\u8A18\u61B6\u306B\u306A\u3063\u3066\u304A\u308A\u307E\u3059\u3002\n\"\u7279\u5B9A\u4ED6\u8005\u8A18\u61B6\"\u3068\u3067\u3082\u547C\u3073\u307E\u3057\u3087\u3046\u304B\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 60, y: -185}
    maskSize: {x: 155, y: 210}
  - message: "\u3053\u306E\u8A18\u61B6\u306F\u304B\u3064\u3066\u306E\u81EA\u5206\u304C\u6C42\u3081\u3066\u3044\u305F\u7B54\u3048\u306B\u306A\u308A\u3046\u308B\u8A18\u61B6\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 60, y: -185}
    maskSize: {x: 155, y: 210}
  - message: "\u771F\u5B9F\u306E\u4EE3\u511F\u3067\u3042\u308B\u75DB\u307F\u306B\u5BFE\u3057\u3066\u3053\u306E\u8A18\u61B6\u306F\u75DB\u307F\u3092\u548C\u3089\u3052\u308B\u93AE\u75DB\u5264\u306E\u3088\u3046\u306A\u3082\u306E\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 60, y: -185}
    maskSize: {x: 155, y: 210}
  - message: "\u3053\u306E\u8A18\u61B6\u306F\u3068\u3066\u3082\u5E0C\u5C11\u306A\u70BA\u75DB\u307F\u3067\u82E6\u3057\u3080\u524D\u306B\u7372\u5F97\u3059\u308B\u3053\u3068\u3092\u304A\u3059\u3059\u3081\u3057\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 60, y: -185}
    maskSize: {x: 155, y: 210}
  - message: "\u305D\u3057\u3066\u6700\u5F8C\u306B\u3053\u306E\"\u66D6\u6627\u8A18\u61B6\"\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: -195}
    maskSize: {x: 155, y: 210}
  - message: "\u6B63\u76F4\u30DC\u30AF\u306B\u3082\u3053\u306E\u5B9F\u614B\u304C\u308F\u304B\u3089\u306A\u3044\u306E\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: -195}
    maskSize: {x: 155, y: 210}
  - message: "\u5206\u304B\u3063\u3066\u3044\u308B\u306E\u306F\u9577\u3044VOID RED\u306E\u6B74\u53F2\u306E\u4E2D\u3067\u304B\u3064\u3066\u306E\u5BA2\u4EBA\u304C\u6B8B\u3057\u305F\u3082\u306E\u3068\u3044\u3046\u3053\u3068\u3060\u3051\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: -195}
    maskSize: {x: 155, y: 210}
  - message: "\u3053\u306E\u8A18\u61B6\u306F\u7A00\u306B\u5B58\u5728\u3092\u73FE\u3057\u3001\u53C2\u52A0\u8005\u306E\u6551\u3044\u3068\u306A\u308B\u306A\u3093\u3066\u5642\u304C\u3042\u308A\u307E\u3059\u304C..."
    isPlayerDialog: 0
    maskPosition: {x: 185, y: -195}
    maskSize: {x: 155, y: 210}
  - message: "\u6B63\u76F4\u53C2\u52A0\u8005\u306E\u82E6\u3057\u3080\u59FF\u304C\u597D\u304D\u306A\u30DC\u30AF\u306B\u3068\u3063\u3066\u306F\u9762\u767D\u304F\u306A\u3044\u5B58\u5728\u3067\u3059\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: -195}
    maskSize: {x: 155, y: 210}
