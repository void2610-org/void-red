  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: BattleTutorial2
  m_EditorClassIdentifier: 
  tutorialId: Battle2
  steps:
  - message: "\u3053\u3053\u3067\u306F\u7CBE\u795E\u672D\u306E\u8A73\u7D30\u3092\n\u898B\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 850, y: 550}
  - message: "\u3053\u308C\u3089\u306E\u300C\u30AD\u30FC\u30EF\u30FC\u30C9\u300D\u3092\u78BA\u8A8D\u3057\u3001\n\u51FA\u3059\u672D\u3092\u6C7A\u3081\u308B\u3068\u826F\u3044\u3067\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: 75}
    maskSize: {x: 400, y: 50}
  - message: "\u7CBE\u795E\u672D\u306B\u306F\u300C\u5C5E\u6027\u300D\u304C\n\u8A2D\u5B9A\u3055\u308C\u3066\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: 0}
    maskSize: {x: 400, y: 50}
  - message: "\u30C6\u30FC\u30DE\u306E\u30A4\u30E1\u30FC\u30B8\u306B\u8FD1\u3044\u5C5E\u6027\u306E\u672D\u3092\u9078\u3076\u3053\u3068\u3067\u3001\n\u3088\u308A\u9AD8\u3044\u30B9\u30B3\u30A2\u3092\u5F97\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: 0}
    maskSize: {x: 400, y: 50}
  - message: "\u7CBE\u795E\u672D\u306E\u5C5E\u6027\u306F\u3053\u3053\u3067\u78BA\u8A8D\u3067\u304D\u307E\u3059\u304C\u3001\n\u30C6\u30FC\u30DE\u306E\u5C5E\u6027\u306F\u305D\u306E\u540D\u524D\u3084\u30AD\u30FC\u30EF\u30FC\u30C9\u304B\u3089\u63A8\u6E2C\u3059\u308B\u5FC5\u8981\u304C\u3042\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: 0}
    maskSize: {x: 400, y: 50}
  - message: "\u7CBE\u795E\u672D\u306B\u306F\u300C\u5D29\u58CA\u95BE\u5024(\u3057\u304D\u3044\u3061)\u300D\u304C\u8A2D\u5B9A\u3055\u308C\u3066\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: -75}
    maskSize: {x: 400, y: 50}
  - message: "\u3053\u306E\u5024\u3092\u8D85\u3048\u305F\u7CBE\u795E\u30D9\u30C3\u30C8\u3092\u3059\u308B\u3068\u3001\n\u6025\u6FC0\u306B\u672D\u306E\u5D29\u58CA\u78BA\u7387\u304C\u4E0A\u304C\u308A\u3001\n\u5D29\u58CA\u3059\u308B\u3068\u305D\u306E\u672D\u3092\u4F7F\u7528\u3059\u308B\u3053\u3068\u304C\u3067\u304D\u306A\u304F\u306A\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: -75}
    maskSize: {x: 400, y: 50}
  - message: "\u7CBE\u795E\u30D9\u30C3\u30C8\u306B\u3064\u3044\u3066\u306F\n\u8FFD\u3063\u3066\u8AAC\u660E\u3057\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 185, y: -75}
    maskSize: {x: 0, y: 0}
