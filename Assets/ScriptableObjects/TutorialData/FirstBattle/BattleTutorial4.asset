  steps:
  - message: "\u7CBE\u795E\u672D\u3092\u9078\u3093\u3060\u3089\u3001\u3053\u306E\u6B6F\u8ECA\u3092\u56DE\u3057\u3066\n\u672D\u306E\u300C\u51FA\u3057\u65B9\u300D\u3092\u9078\u3093\u3067\u304F\u3060\u3055\u3044\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -420, y: -180}
    maskSize: {x: 250, y: 250}
  - message: "\u78BA\u4FE1\u306F\u8FF7\u3044\u306B\u5F37\u304F\u3001\u8FF7\u3044\u306F\u885D\u52D5\u306B\u5F37\u304F\u3001\n\u885D\u52D5\u306F\u78BA\u4FE1\u306B\u5F37\u3044\u95A2\u4FC2\u306B\u3042\u308A\u307E\u3059\u3002\n"
    isPlayerDialog: 0
    maskPosition: {x: -420, y: -180}
    maskSize: {x: 250, y: 250}
  - message: "\u5BFE\u6226\u76F8\u624B\u306B\u3088\u308A\u51FA\u3057\u65B9\u306E\u50BE\u5411\u304C\u7570\u306A\u308B\u306E\u3067\u3001\n\u3088\u308A\u9069\u5207\u306A\u51FA\u3057\u65B9\u3092\u9078\u3076\u3088\u3046\u306B\u3057\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -420, y: -180}
    maskSize: {x: 0, y: 0}
  - message: "\u76F8\u624B\u306E\u51FA\u3057\u65B9\u3088\u308A\u5F37\u3051\u308C\u3070\u30B9\u30B3\u30A2\u304C\u5897\u52A0\u3057\u3001\n\u76F8\u624B\u306E\u51FA\u3057\u65B9\u3088\u308A\u5F31\u3051\u308C\u3070\u30B9\u30B3\u30A2\u304C\u6E1B\u5C11\u3057\u307E\u3059\u3002"
