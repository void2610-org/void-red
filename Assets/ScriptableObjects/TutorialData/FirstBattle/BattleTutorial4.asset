  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: BattleTutorial4
  m_EditorClassIdentifier: 
  tutorialId: Battle4
  steps:
  - message: "\u3053\u3053\u3067\u306F\u7CBE\u795E\u30D9\u30C3\u30C8\u306E\u5024\u3092\u6C7A\u3081\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059"
    isPlayerDialog: 0
    maskPosition: {x: 400, y: -210}
    maskSize: {x: 250, y: 150}
  - message: "\u7CBE\u795E\u30D9\u30C3\u30C8\u3068\u306F\u3042\u306A\u305F\u304C\u7CBE\u795E\u672D\u306B\u8CED\u3051\u308B\u601D\u3044\u306E\u5F37\u3055\u3092\u6570\u5024\u5316\u3057\u305F\u3082\u306E\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 400, y: -210}
    maskSize: {x: 250, y: 150}
  - message: "\u7CBE\u795E\u30D9\u30C3\u30C8\u306E\u5024\u304C\u5927\u304D\u3044\u307B\u3069\u30B9\u30B3\u30A2\u306B\u500D\u7387\u304C\u304B\u304B\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3057\u304B\u3057\u672D\u306F\u8106\u304F\u3001\u3042\u307E\u308A\u6CE8\u304E\u8FBC\u307F\u3059\u304E\u308B\u3068\u300C\u5D29\u58CA\u300D\u306E\u6050\u308C\u304C\u3042\u308B\u306E\u3067\u30D9\u30C3\u30C8\u3059\u308B\u3068\u304D\u306F\u3088\u308A\u614E\u91CD\u306B\u884C\u3063\u3066\u304F\u3060\u3055\u3044\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u7CBE\u795E\u672D\u306E\u8A73\u7D30\u306B\u8A18\u8F09\u3055\u308C\u3066\u3044\u308B\u300C\u5D29\u58CA\u95BE\u5024\u300D\u3092\u53C2\u8003\u306B\u30D9\u30C3\u30C8\u3059\u308B\u3068\u826F\u3044\u3067\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u6642\u306B\u306F\u672D\u304C\u5D29\u58CA\u3059\u308B\u899A\u609F\u3067\u52DD\u8CA0\u3092\u3059\u308B\u5834\u9762\u304C\u6765\u308B\u304B\u3082\u3057\u308C\u307E\u305B\u3093\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u305D\u3057\u3066\u3042\u306A\u305F\u306E\u7CBE\u795E\u5024\u3092\u30D9\u30C3\u30C8\u3059\u308B\u524D\u306B\u6CE8\u610F\u3057\u3066\u3044\u305F\u3060\u304D\u305F\u3044\u306E\u306F\u3053\u306E\u6570\u5024\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -460, y: 150}
    maskSize: {x: 120, y: 230}
  - message: "\u3053\u306E\u6570\u5024\u306F\u3042\u306A\u305F\u3068\u5BFE\u6226\u76F8\u624B\u306E\u7CBE\u795E\u5024\u6B8B\u91CF\u3092\u793A\u3057\u307E\u3059\u3001\n\u3053\u3053\u3067\u306F\u3042\u306A\u305F\u3068\u30DC\u30AF\u306E\u3067\u3059\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -460, y: 150}
    maskSize: {x: 120, y: 230}
  - message: "\u3053\u306E\u6570\u5024\u304C0\u306B\u306A\u3063\u3066\u3057\u307E\u3046\u3068\u3042\u306A\u305F\u306E\u7CBE\u795E\u529B\u306F\u6D88\u3048\u3001\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u306B\u53C2\u52A0\u3057\u7D9A\u3051\u308B\u306E\u304C\u56F0\u96E3\u306B\u306A\u3063\u3066\u3057\u307E\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: -460, y: 150}
    maskSize: {x: 120, y: 230}
