  m_Name: BattleTutorial1
  m_EditorClassIdentifier: 
  tutorialId: Battle1
  steps:
  - message: "\u305D\u308C\u3067\u306F\u65E9\u901F\u6A21\u64EC\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u3092\u3057\u3066\u3044\u304D\u307E\u3057\u3087\u3046\u304B\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u30DC\u30AF\u304C\u5BFE\u6226\u76F8\u624B\u3060\u3068\u601D\u3063\u3066\u3084\u3063\u3066\u307F\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u2026\u3002"
    isPlayerDialog: 1
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u308F\u304B\u3063\u305F\u3002"
    isPlayerDialog: 1
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u306E\u90E8\u5206\u306B\u306F\u305D\u306E\u30BF\u30FC\u30F3\u306E\u5546\u54C1\u30C6\u30FC\u30DE\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 425, y: 90}
    maskSize: {x: 175, y: 65}
  - message: "\u30AB\u30FC\u30BD\u30EB\u3092\u30C6\u30FC\u30DE\u306E\u4E0A\u306B\u7F6E\u304F\u304B\u30DC\u30BF\u30F3\u3092\u62BC\u3059\u3068\u3001\u305D\u306E\u30C6\u30FC\u30DE\u306E\u30AD\u30FC\u30EF\u30FC\u30C9\u304C\u6D6E\u304B\u3073\u4E0A\u304C\u308A\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 425, y: 90}
    maskSize: {x: 175, y: 65}
  - message: "\u3042\u306A\u305F\u306E\u9078\u629E\u3057\u305F\u7CBE\u795E\u672D\u306E\u30AD\u30FC\u30EF\u30FC\u30C9\u304C\u30C6\u30FC\u30DE\u306E\u30AD\u30FC\u30EF\u30FC\u30C9\u3068\u5408\u81F4\u3057\u305F\u6570\u306B\u5FDC\u3058\u3066\u3001\u30B9\u30B3\u30A2\u304C\u5F97\u3089\u308C\u307E\u3059\u3002\n\u7CBE\u795E\u672D\u306B\u3064\u3044\u3066\u306F\u5F8C\u306B\u89E3\u8AAC\u3057\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 425, y: 90}
    maskSize: {x: 175, y: 65}
  - message: "\u9AD8\u30B9\u30B3\u30A2\u3092\u5F97\u308B\u306B\u306F\u30C6\u30FC\u30DE\u306E\u30AD\u30FC\u30EF\u30FC\u30C9\u3068\u5408\u81F4\u3059\u308B\u3082\u306E\u304C\u591A\u3044\u7CBE\u795E\u672D\u3092\u9078\u3076\u3068\u826F\u3044\u3067\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 425, y: 90}
    maskSize: {x: 175, y: 65}
  - message: "\u3053\u306E\u30B9\u30B3\u30A2\u304C\u9AD8\u3044\u307B\u3046\u304C\u52DD\u5229\u3057\u3001\u5546\u54C1\u30C6\u30FC\u30DE\u3068\u306A\u3063\u305F\u8A18\u61B6\u3092\u7372\u5F97\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 425, y: 90}
    maskSize: {x: 175, y: 65}
  - message: "\u3055\u304D\u307B\u3069\u914D\u3089\u308C\u305F\u672D\u306F\u300C\u7CBE\u795E\u672D\u300D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 270, y: -110}
    maskSize: {x: 425, y: 250}
  - message: "\u3053\u308C\u3092\u5DEE\u3057\u51FA\u3059\u3053\u3068\u3067\u3042\u306A\u305F\u306E\u611F\u60C5\u3092\u8CED\u3051\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 270, y: -110}
    maskSize: {x: 425, y: 250}
  - message: "\u4EFB\u610F\u306E\u672D\u3092\u9078\u3093\u3067\u8A73\u7D30\u3092\u958B\u304F\u3053\u3068\u3067\u305D\u306E\u672D\u306E\u7279\u6027\u3092\u898B\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 425, y: 90}
    maskSize: {x: 175, y: 65}
