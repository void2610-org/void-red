  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: MemoryGrowthPhase
  m_EditorClassIdentifier: Assembly-CSharp::TutorialData
  steps:
  - message: "\u52DD\u5229\u3067\u304D\u307E\u3057\u305F\u306D\u3002\u3053\u3046\u3084\u3063\u3066\u30B9\u30AD\u30EB\u3092\u4F7F\u7528\u3059\u308C\u3070\u30D0\u30C8\u30EB\u3092\u6709\u5229\u306B\u9032\u3081\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u305F\u3060\u3057\u3001\u30B9\u30AD\u30EB\u306F1\u56DE\u306E\u30D0\u30C8\u30EB\u306B\u3064\u304D1\u56DE\u306E\u307F\u3057\u304B\u4F7F\u7528\u3067\u304D\u306A\u3044\u306E\u3067\u4F7F\u3044\u6240\u306F\u3057\u3063\u304B\u308A\u3068\u8003\u3048\u3066\u304F\u3060\u3055\u3044\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u611F\u60C5\u72B6\u614B\u306B\u5DE6\u53F3\u3055\u308C\u308B\u3001\u4E00\u56DE\u9650\u308A\u306E\u5927\u6280\u307F\u305F\u3044\u306A\u3082\u306E\u304B\u3002\u4E0A\u624B\u304F\u4F7F\u3048\u308B\u304B\u5FC3\u914D\u3060\u306A...\u3002"
    isPlayerDialog: 1
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u305D\u3053\u306F\u52DD\u5229\u6761\u4EF6\u3068\u81EA\u5206\u306E\u624B\u672D\u3092\u898B\u3066\u3057\u3063\u304B\u308A\u8003\u3048\u308B\u306E\u3067\u3059\u3088\u3002\u5927\u62B5\u306F\u3088\u304F\u8003\u3048\u308C\u3070\u4F7F\u3044\u6240\u306F\u9593\u9055\u308F\u306A\u3044\u306F\u305A\u3067\u3059\u3088\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u305F\u3060\u76E4\u9762\u7684\u306B\u30B9\u30AD\u30EB\u3092\u4F7F\u3063\u3066\u3082\u610F\u5473\u306E\u306A\u3044\u5C40\u9762\u306F\u3042\u308B\u3068\u601D\u3044\u307E\u3059\u304C\u3002\u305D\u3053\u306F\u81E8\u6A5F\u5FDC\u5909\u306B\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3093\u30FC\u52B1\u307E\u3055\u308C\u3066\u308B\u306E\u304B\u3001\u5C0F\u99AC\u9E7F\u306B\u3055\u308C\u3066\u308B\u306E\u304B\u3002"
    isPlayerDialog: 1
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3054\u60F3\u50CF\u306B\u304A\u4EFB\u305B\u3057\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u308C\u3067\u3001\u4E00\u901A\u308A\u306E\u30EB\u30FC\u30EB\u306F\u3059\u3079\u3066\u304A\u6559\u3048\u3057\u307E\u3057\u305F\u3002\u3069\u3046\u3067\u3057\u305F\u304B\uFF1F\u96E3\u3057\u3051\u308C\u3070\u3042\u306A\u305F\u304C\u899A\u3048\u308B\u307E\u3067\u4F55\u56DE\u3067\u3082\u6559\u3048\u307E\u3059\u3088\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
