  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: MemoryGrowthPhase
  m_EditorClassIdentifier:
  steps:
  - message: "\u52DD\u5229\u3059\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3057\u305F\u306D\u3002\u3053\u306E\u3088\u3046\u306B\u30B9\u30AD\u30EB\u3092\u4F7F\u7528\u3059\u308B\u3053\u3068\u3067\u30D0\u30C8\u30EB\u3092\u6709\u5229\u306B\u9032\u3081\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u305F\u3060\u3057\u3001\u30B9\u30AD\u30EB\u306F1\u56DE\u306E\u30D0\u30C8\u30EB\u306B\u3064\u304D1\u56DE\u306E\u307F\u3057\u304B\u4F7F\u7528\u3067\u304D\u306A\u3044\u306E\u3067\u4F7F\u3044\u6240\u306F\u3057\u3063\u304B\u308A\u3068\u8003\u3048\u3066\u304F\u3060\u3055\u3044\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u3053\u3067\u306F\u3042\u306A\u305F\u304C\u7372\u5F97\u3057\u305F\u8A18\u61B6\u30AB\u30FC\u30C9\u305D\u3057\u3066\u305D\u308C\u3089\u304C\u4F5C\u308A\u4E0A\u3052\u305F\u8A18\u61B6\u30C6\u30FC\u30DE\u3092\u95B2\u89A7\u3059\u308B\u3053\u3068\u304C\u53EF\u80FD\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 950, y: 500}
  - message: "\u3042\u306A\u305F\u306F\u3053\u306E\u8A18\u61B6\u30C6\u30FC\u30DE\u3092\u53D6\u308A\u8FBC\u3080\u3053\u3068\u3067\u81EA\u5206\u3092\u6210\u9577\u3055\u305B\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 950, y: 500}
  - message: "\u3053\u308C\u3089\u304C\u3082\u305F\u3089\u3059\u5909\u5316\u306F\u3042\u306A\u305F\u306B\u5E78\u904B\u3092\u3082\u305F\u3089\u3059\u304B\u3002\n\u306F\u305F\u307E\u305F\u7D76\u671B\u3092\u3082\u305F\u3089\u3059\u306E\u304B\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u305F\u3060\u4E00\u3064\u8A00\u3048\u308B\u306E\u306F\u3042\u306A\u305F\u306F\u524D\u306B\u9032\u3093\u3067\u3044\u308B\u3068\u3044\u3046\u3053\u3068\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u308C\u3067\u3001\u57FA\u672C\u64CD\u4F5C\u306F\u3059\u3079\u3066\u4F53\u9A13\u3067\u304D\u307E\u3057\u305F\u3002\u3069\u3046\u3067\u3057\u305F\u304B\uFF1F\u96E3\u3057\u3051\u308C\u3070\u3042\u306A\u305F\u304C\u899A\u3048\u308B\u307E\u3067\u4F55\u56DE\u3067\u3082\u6559\u3048\u307E\u3059\u3088\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
