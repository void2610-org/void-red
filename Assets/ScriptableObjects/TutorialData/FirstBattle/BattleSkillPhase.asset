  m_Script: {fileID: 11500000, guid: be39089e8c27e4fcba38fdd88f2042ba, type: 3}
  m_Name: BattleSkillPhase
  m_EditorClassIdentifier: Assembly-CSharp::TutorialData
  steps:
  - message: "\u5727\u52DD\u3067\u3057\u305F\u306D\u3002\u4ECA\u56DE\u306E\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u3067\u306F1\u679A\u3057\u304B\u843D\u672D\u3055\u308C\u306A\u304B\u3063\u305F\u306E\u3067\u3042\u306A\u305F\u306E\u30AB\u30FC\u30C9\u304C\u4E00\u756A\u5F37\u304F\u306A\u3063\u3066\u3044\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u308C\u306F\u6301\u8AD6\u306A\u306E\u3067\u3059\u304C\u3001\u78BA\u5B9F\u306B\u52DD\u3066\u308B\u8A66\u5408\u3067\u306F\u52DD\u3063\u3066\u304A\u304F\u306E\u304C\u30AA\u30B9\u30B9\u30E1\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u7D9A\u3044\u3066\u306E\u8A66\u5408\u3067\u3059\u304C\u3001\u624B\u6301\u3061\u306B\u306F3\u306E\u30AB\u30FC\u30C9\u3057\u304B\u3042\u308A\u307E\u305B\u3093\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: -260}
    maskSize: {x: 550, y: 80}
  - message: "\u76F8\u624B\u306E\u624B\u6301\u3061\u3082\u5168\u30663\u306E\u30AB\u30FC\u30C9\u306A\u305F\u3081\u3053\u3053\u306F\u30B9\u30AD\u30EB\u3092\u4F7F\u3044\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: -260}
    maskSize: {x: 550, y: 80}
  - message: "\u30B9\u30AD\u30EB\u306F\u3042\u306A\u305F\u306E\u611F\u60C5\u72B6\u614B\u306E\u3082\u306E\u3092\u4F7F\u7528\u3059\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: -260}
    maskSize: {x: 550, y: 80}
  - message: "\u559C\u3073\u306E\u30B9\u30AD\u30EB\u306F\u3001\u300C\u81EA\u5206\u306E\u51FA\u3057\u305F\u30AB\u30FC\u30C9\u306E\u6570\u5B57\u30922\u500D\u306B\u3059\u308B\u300D\u3068\u3044\u3046\u3082\u306E\u3067\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: -260}
    maskSize: {x: 550, y: 80}
  - message: "\u4ED6\u306E\u30B9\u30AD\u30EB\u306F\u3001\u30D8\u30EB\u30D7\u304B\u3089\u4E00\u89A7\u3092\u78BA\u8A8D\u3067\u304D\u307E\u3059\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: -260}
    maskSize: {x: 550, y: 80}
  - message: "\u30D8\u30EB\u30D7\u304C\u4F55\u304B\u306F\u30DC\u30AF\u306B\u306F\u308F\u304B\u308A\u307E\u305B\u3093\u3051\u3069\u306D\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u3053\u3053\u3067\u30B9\u30AD\u30EB\u3092\u767A\u52D5\u3067\u304D\u307E\u3059\u3002\u65E9\u901F\u767A\u52D5\u3057\u3066\u307F\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: -260}
    maskSize: {x: 550, y: 80}
