  steps:
  - message: "\u7CBE\u795E\u672D\u3092\u9078\u3093\u3060\u3089\u3001\u3053\u306E\u6B6F\u8ECA\u3092\u56DE\u3057\u3066\u672D\u306E\u51FA\u3057\u65B9\u3092\u9078\u3093\u3067\u304F\u3060\u3055\u3044\u3002"
