    maskSize: {x: 0, y: 0}
  - message: "\u78BA\u4FE1\u306F\u8FF7\u3044\u306B\u5F37\u304F\u3001\u8FF7\u3044\u306F\u885D\u52D5\u306B\u5F37\u304F\u3001\u885D\u52D5\u306F\u78BA\u4FE1\u306B\u5F37\u3044\u95A2\u4FC2\u306B\u3042\u308A\u307E\u3059\u3002\n"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u5BFE\u6226\u76F8\u624B\u306B\u5FDC\u3058\u3066\u51FA\u3057\u65B9\u306E\u50BE\u5411\u304C\u3042\u308B\u306E\u3067\u3001\u3088\u308A\u5F37\u3044\u51FA\u3057\u65B9\u3092\u9078\u3076\u3088\u3046\u306B\u3057\u307E\u3057\u3087\u3046\u3002"
    isPlayerDialog: 0
    maskPosition: {x: 0, y: 0}
    maskSize: {x: 0, y: 0}
  - message: "\u76F8\u624B\u306E\u51FA\u3057\u65B9\u3068\u306E\u76F8\u6027\u306B\u3088\u3063\u3066\u30B9\u30B3\u30A2\u304C\u5897\u6E1B\u3057\u307E\u3059\u3002"
