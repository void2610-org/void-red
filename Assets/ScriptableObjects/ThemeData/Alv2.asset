  title: "\u540D\u524D\u306E\u306A\u3044\u4E88\u611F"
  description: "\u5149\u306F\u3044\u3064\u3082\u3001\u79C1\u4EE5\u5916\u3092\u7167\u3089\u3057\u3066\u3044\u304F\u3002\n\u305D\u306E\u307E\u306A\u3056\u3057\u306B\u3001\u79C1\u306F\u542B\u307E\u308C\u3066\u3044\u306A\u3044\u6C17\u304C\u3057\u3066\u3002\n\n\u671F\u5F85\u306F\u3001\u307E\u3076\u3057\u304F\u3066\u3001\u75DB\u304F\u3066\u3001\n\u5FDC\u3048\u3089\u308C\u308B\u81EA\u5206\u304C\u3001\u3069\u3053\u306B\u3082\u898B\u3064\u304B\u3089\u306A\u3044\u3002\n\n\u9854\u3092\u3042\u3052\u308B\u3053\u3068\u304C\u3067\u304D\u305F\u306A\u3089\u2014\u2014\n\u305D\u306E\u4E88\u611F\u3060\u3051\u304C\u3001\u307E\u3060\u8A00\u8449\u306B\u306A\u3089\u305A\u306B\u6EF2\u3093\u3067\u3044\u308B\u3002\n\n\u81C6\u75C5\u306A\u79C1\u306F\u3001\u9CE5\u7C60\u306E\u4E2D\u3067\u3001\n\u307E\u3076\u3057\u3055\u3092\u907F\u3051\u308B\u3088\u3046\u306B\u3001\u305D\u3063\u3068\u4FEF\u3044\u3066\u3044\u305F\u3002"
  attributeMultipliers:
    serializedList:
    - key: 0
      value: 1.2
    - key: 1
      value: 1
    - key: 2
      value: 1.3
    - key: 3
      value: 1
    - key: 4
      value: 1.4
    - key: 5
      value: 1.1
  keywords:
  - "\u8F2A\u90ED\u306E\u306A\u3044\u672A\u6765"
  - "\u9707\u3048"
  - "\u63FA\u308C\u308B\u8DB3\u5143"
  - "\u901A\u308A\u904E\u304E\u308B\u5149"
  - "\u5C4A\u304B\u306A\u3044\u58F0"
  - "\u540D\u3082\u306A\u304D\u5149\u306E\u4E88\u611F"
  dialogues:
  - isPlayer: 1
    message: "\u2026\u2026\u8AAD\u3093\u3067\u3066\u3001\u80F8\u304C\u3056\u308F\u3064\u3044\u305F\u3002"
  - isPlayer: 1
    message: "\u8AB0\u304B\u306B\u898B\u3066\u307B\u3057\u3044\u306E\u306B\u3001\u898B\u3089\u308C\u308B\u306E\u304C\u6016\u304F\u3066\u3002\n\u305D\u306E\u6C17\u6301\u3061\u3001\u305A\u3063\u3068\u62B1\u3048\u3066\u308B\u3088\u3046\u306A\u8A18\u61B6\u306B\u611F\u3058\u305F\u3002"
  - isPlayer: 0
    message: "\u898B\u3089\u308C\u308B\u3053\u3068\u3092\u6016\u304C\u308B\u306E\u306F\u3001\n\u81EA\u5206\u3067\u4FA1\u5024\u304C\u306A\u3044\u3068\u6C7A\u3081\u3066\u3044\u308B\u304B\u3089\u3067\u3057\u3087\u3046\u3002\n"
  - isPlayer: 0
    message: "\u5149\u306E\u5916\u306B\u3044\u308B\u306E\u306F\u3001\u8AB0\u304B\u306B\u8FFD\u3044\u3084\u3089\u308C\u305F\u306E\u3067\u306F\u306A\u304F\u3001\n\u81EA\u5206\u3067\u305D\u3053\u3092\u9078\u3093\u3060\u3002\n"
  - isPlayer: 0
    message: "\u307E\u3076\u3057\u3055\u3092\u907F\u3051\u305F\u306E\u306F\u3001\u4ED6\u3067\u3082\u306A\u3044\u672C\u4EBA\u3067\u3059\u3002"
  - isPlayer: 1
    message: "\u2026\u2026\u305D\u3093\u306A\u3075\u3046\u306B\u8A00\u3044\u5207\u3089\u306A\u3044\u3067\u3088\u3002"
  - isPlayer: 1
    message: "\u9078\u3093\u3060\u3063\u3066\u3044\u3046\u3088\u308A\u3001\u3069\u3046\u3057\u3066\u3082\u52D5\u3051\u306A\u304B\u3063\u305F\u3060\u3051\u304B\u3082\u3057\u308C\u306A\u3044\u3002"
  - isPlayer: 0
    message: "\u305D\u308C\u306B\u2026\u2026\u307B\u3093\u306E\u5C11\u3057\u3060\u3051\u3001\u524D\u3092\u5411\u304D\u305F\u3044\u6C17\u6301\u3061\u3082\u3042\u3063\u305F\u3088\u3046\u306A\u2026\u2026"
  - isPlayer: 0
    message: "\u524D\u3092\u5411\u304D\u305F\u3044\u3001\u3067\u3059\u304B\u3002\n\u305D\u308C\u306F\u4E88\u611F\u3067\u3042\u3063\u3066\u3001\u307E\u3060\u8A00\u8449\u306B\u3082\u306A\u3089\u306A\u3044\u3002"
  - isPlayer: 0
    message: "\u6EF2\u3093\u3060\u307E\u307E\u306E\u60F3\u3044\u3067\u306F\u3001\u8AB0\u306E\u5FC3\u3082\u63FA\u3089\u305B\u307E\u305B\u3093\u3088\u3002"
  - isPlayer: 1
    message: "\u3067\u3082\u2026\u2026\u305D\u308C\u3067\u3082\u3001\u4F55\u304B\u304C\u52D5\u304D\u51FA\u3059\u77AC\u9593\u3063\u3066\u3042\u308B\u3068\u601D\u3046\u3002"
  - isPlayer: 0
    message: "\u8A00\u8449\u306B\u306A\u3089\u306A\u304F\u3066\u3082\u3001\u6C17\u6301\u3061\u304C\u3042\u308B\u306A\u3089\u2026\u2026\n\u2026\u2026\u3044\u3084\u3001\u3067\u3082\u2026\u2026\u3046\u307E\u304F\u8A00\u3048\u306A\u3044\u2026\u2026"
  - isPlayer: 0
    message: "\u8A00\u3048\u306A\u3044\u306A\u3089\u3001\u5C4A\u304B\u306A\u3044\u3002\n\u3053\u306E\u8A18\u61B6\u306F\u3001\u307E\u3060\u305D\u306E\u624B\u524D\u306B\u3044\u308B\u3002"
  - isPlayer: 0
    message: "\u305F\u3060\u305D\u308C\u3060\u3051\u306E\u3053\u3068\u3067\u3059\u3002 "
