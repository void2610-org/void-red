  m_Script: {fileID: 11500000, guid: e825166e0c2c14bab83629c2b18411fc, type: 3}
  m_Name: Alv1
  m_EditorClassIdentifier: 
  title: "\u5FAE\u7B11\u307F\u306E\u6B8B\u97FF"
  description: "\u305F\u304F\u3055\u3093\u5931\u3063\u305F\u3002\n\u540D\u524D\u3082\u3001\u58F0\u3082\u3001\u89E6\u308C\u3089\u308C\u306A\u3044\u512A\u3057\u3055\u3082\u3002\n\n\u305D\u308C\u3067\u3082\u79C1\u306F\u3001\u624B\u3092\u53D6\u3063\u305F\u3002\n\u3082\u3046\u8AB0\u3082\u3001\u50B7\u3064\u3051\u305F\u304F\u306A\u304B\u3063\u305F\u304B\u3089\u3002\n\n\u3082\u3057\u3059\u3079\u3066\u3092\u53D7\u3051\u5165\u308C\u3089\u308C\u305F\u306A\u3089\u3001\n\u3082\u3046\u4E00\u5EA6\u3001\u3042\u306A\u305F\u306B\u5FAE\u7B11\u307F\u304B\u3051\u3066\u307F\u305F\u3044\u3002\n\n\u6C7A\u3057\u3066\u77ED\u3044\u6642\u9593\u3067\u306F\u306A\u3044\u3051\u308C\u3069\u3001\n\u5C11\u3057\u305A\u3064\u3001\u540C\u3058\u65B9\u89D2\u3078\u6B69\u3044\u3066\u3044\u3051\u305F\u306A\u3089\u3002\n\n\u305D\u306E\u6B8B\u97FF\u304C\u3001\u9759\u304B\u306B\u79C1\u305F\u3061\u3092\u307B\u3069\u3044\u3066\u3044\u304F\u3002"
  attributeMultipliers:
    serializedList:
    - key: 0
      value: 1.5
    - key: 1
      value: 1
    - key: 2
      value: 1.1
    - key: 3
      value: 1.2
    - key: 4
      value: 1.1
    - key: 5
      value: 0.9
  keywords: 0100000005000000
  dialogues:
  - isPlayer: 0
    message: "\u3053\u308C\u306F\u3001\u30DC\u30AF\u304C\u81EA\u4F5C\u3057\u305F\u8A18\u61B6\u306E\u30EC\u30D7\u30EA\u30AB\u54C1\u3067\u3059\u3002\n\u5B9F\u969B\u306B\u4F53\u9A13\u3057\u305F\u8A18\u61B6\u3092\u3082\u3068\u306B\u3001\u5C11\u3057\u3060\u3051\u624B\u3092\u52A0\u3048\u3066\u3042\u308A\u307E\u3059\u3002"
  - isPlayer: 0
    message: "\u3055\u3042\u3001\u3053\u306E\u8A18\u61B6\u306B\u5BFE\u3057\u3066\u306E\u201C\u601D\u3044\u201D\u306B\u3064\u3044\u3066\u8A00\u8449\u3092\u4EA4\u308F\u3057\u3066\u3044\u304D\u307E\u3057\u3087\u3046\u3002"
  - isPlayer: 1
    message: "\u8A00\u8449\u3092\u4EA4\u308F\u3059\u2026\uFF1F"
  - isPlayer: 1
    message: "\u8A69\u7684\u3067\u7DBA\u9E97\u306A\u8A18\u61B6\u3063\u3066\u5370\u8C61\u3057\u304B\u306A\u3044\u3051\u3069\u3002\n\u305D\u3082\u305D\u3082\u3001\u305D\u3093\u306A\u3053\u3068\u8A71\u3057\u3066\u3069\u3046\u3059\u308B\u306E\uFF1F"
  - isPlayer: 0
    message: "\u672C\u5F53\u306B\u3042\u306A\u305F\u306F\u920D\u3044\u3067\u3059\u306D\u3002\u3075\u3075\u3002"
  - isPlayer: 0
    message: "\u3053\u306E\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u306F\u3001\u76F8\u624B\u306E\u8A00\u8449\u3084\u6027\u683C\u304B\u3089\u672D\u306E\u51FA\u3057\u65B9\u3092\u898B\u6975\u3081\u308B\u306E\u304C\u5B9A\u77F3\u306A\u3093\u3067\u3059\u3088\u3002"
  - isPlayer: 0
    message: "\u4F55\u3082\u5F97\u3089\u308C\u305A\u306B\u7A7A\u3063\u307D\u306E\u4EBA\u5F62\u306E\u307E\u307E\u3067\u7D42\u308F\u3089\u306A\u3044\u3088\u3046\u306B\u3001\n\u60C5\u5831\u53CE\u96C6\u306F\u3057\u3066\u304A\u304F\u3079\u304D\u3067\u3059\u3002"
  - isPlayer: 1
    message: "\u3042\u306A\u305F\u3063\u3066\u3001\u55A7\u5629\u8170\u3067\u3057\u304B\u8A71\u305B\u306A\u3044\u306E\uFF1F\n\u30A2\u30C9\u30D0\u30A4\u30B9\u306F\u3042\u308A\u304C\u305F\u3044\u3051\u3069\u3001\u3082\u3046\u5C11\u3057\u512A\u3057\u304F\u3057\u3066\u304F\u308C\u3066\u3082\u3044\u3044\u3093\u3058\u3083\u306A\u3044\uFF1F"
  - isPlayer: 0
    message: "\u3053\u308C\u306F\u5931\u793C\u3002\u30DC\u30AF\u306E\u914D\u616E\u304C\u8DB3\u308A\u307E\u305B\u3093\u3067\u3057\u305F\u3002"
  - isPlayer: 0
    message: "\u3042\u306A\u305F\u304C\u3088\u308A\u591A\u304F\u306E\u8A18\u61B6\u3092\u843D\u672D\u3067\u304D\u308B\u3088\u3046\u306B\u3001\u5C11\u3057\u3067\u3082\u52A9\u3051\u306B\u306A\u308C\u3070\u3068\u601D\u3063\u305F\u3060\u3051\u3067\u3059\u3002"
  - isPlayer: 0
    message: "\u6C17\u3092\u60AA\u304F\u3057\u306A\u3044\u3067\u304F\u3060\u3055\u3044\u306D\u3002"
  - isPlayer: 1
    message: "\u2026\u2026\u308F\u304B\u3063\u305F\u3002\n\u3058\u3083\u3042\u3001\u3053\u306E\u8A18\u61B6\u306B\u3064\u3044\u3066\u79C1\u304C\u611F\u3058\u305F\u3053\u3068\u3092\u8A71\u3057\u3066\u307F\u308B\u3002"
  - isPlayer: 1
    message: "\u5F7C\u5973\u306F\u3001\u5931\u3063\u3066\u3082\u306A\u304A\u618E\u3057\u307F\u3067\u306F\u306A\u304F\u8D66\u3057\u3092\u9078\u3093\u3060\u3002\n\u3068\u3066\u3082\u5FC3\u304C\u6F84\u3093\u3060\u4EBA\u3060\u3063\u305F\u3093\u3060\u3068\u601D\u3046\u3002"
  - isPlayer: 0
    message: "\u30DC\u30AF\u306B\u306F\u3001\u5F7C\u5973\u306F\u305F\u3060\u8AB0\u304B\u3068\u5411\u304D\u5408\u3046\u52C7\u6C17\u304C\u306A\u304B\u3063\u305F\u3088\u3046\u306B\u898B\u3048\u307E\u3059\u306D\u3002"
  - isPlayer: 0
    message: "\u81C6\u75C5\u3060\u304B\u3089\u3001\u76F8\u624B\u306E\u624B\u3092\u53D6\u308B\u3053\u3068\u3057\u304B\u3067\u304D\u306A\u304B\u3063\u305F\u3002"
  - isPlayer: 0
    message: "\u305D\u308C\u304C\u8D66\u3057\u306B\u898B\u3048\u308B\u306A\u3089\u3001\u305A\u3044\u3076\u3093\u90FD\u5408\u306E\u3044\u3044\u89E3\u91C8\u3067\u3059\u3002"
  - isPlayer: 1
    message: "\u2026\u2026\u3042\u306A\u305F\u3063\u3066\u3001\u672C\u5F53\u306B\u51B7\u305F\u3044\u4EBA\u306A\u306E\u306D\u3002\n\u6027\u683C\u304C\u60AA\u3044\u3063\u3066\u3053\u3068\u3001\u3088\u304F\u5206\u304B\u3063\u305F\u308F\u3002"
  - isPlayer: 0
    message: "\u305D\u306E\u8ABF\u5B50\u3067\u3059\u3002"
  - isPlayer: 0
    message: "\u611F\u60C5\u304C\u52D5\u3044\u305F\u306A\u3089\u3001\u672D\u3082\u52D5\u304F\u3002\n\u305D\u308C\u304C\u3053\u306E\u5834\u306E\u918D\u9190\u5473\u3067\u3059\u304B\u3089\u3002"
