  m_Script: {fileID: 11500000, guid: e825166e0c2c14bab83629c2b18411fc, type: 3}
  m_Name: Cerica1
  m_EditorClassIdentifier: 
  title: "\u58CA\u308C\u305F\u7D04\u675F"
  description: "\u305D\u308C\u306F\u3001\u305F\u3060\u306E\u7D04\u675F\u3060\u3063\u305F\u3002\n\u7279\u5225\u306A\u8A00\u8449\u3058\u3083\u306A\u3044\u3002\n\u65E5\u5E38\u306E\u4E2D\u306B\u3001\u305D\u3063\u3068\u7F6E\u304B\u308C\u3066\u3044\u305F\u3002\n\n\u3051\u308C\u3069\u3001\u79C1\u306B\u306F\u305D\u308C\u304C\u4E16\u754C\u3060\u3063\u305F\u3002\n\u305D\u306E\u5C0F\u3055\u306A\u7D04\u675F\u304C\u3001\u3059\u3079\u3066\u3060\u3063\u305F\u3002\n\n\u679C\u305F\u3055\u308C\u308B\u3053\u3068\u306F\u306A\u304F\u3001\n\u8A00\u8449\u3082\u306A\u304F\u3001\n\u9759\u304B\u306B\u5D29\u308C\u3066\u3044\u3063\u305F\u3002\n\n\u6012\u308A\u3082\u6D99\u3082\u306A\u304F\u3001\n\u4FE1\u983C\u3060\u3051\u304C\u3001\u9759\u304B\u306B\u6D88\u3048\u3066\u3044\u3063\u305F\u3002"
  attributeMultipliers:
    serializedList:
    - key: 0
      value: 1.5
    - key: 1
      value: 1
    - key: 2
      value: 1.1
    - key: 3
      value: 1.2
    - key: 4
      value: 1.1
    - key: 5
      value: 0.9
  keywords: []
  dialogues:
  - isPlayer: 1
    message: "\uFF08\u9759\u304B\u306A\u8A18\u61B6\u2026\u3002\u51B7\u305F\u304F\u6DE1\u3005\u3068\u3057\u3066\u3044\u308B\u3002\uFF09"
  - isPlayer: 1
    message: "\u6012\u3089\u306A\u304B\u3063\u305F\u3093\u3060\u306D\u3002\u8AB0\u3082"
  - isPlayer: 0
    message: "\u3048\u3048\u3002\u3060\u304B\u3089\u3053\u305D\u3001\u58CA\u308C\u305F\u306E\u3088\u3002"
  - isPlayer: 0
    message: "\u201C\u885D\u7A81\u201D\u3063\u3066\u3001\u6642\u306B\u95A2\u4FC2\u3092\u7E4B\u304E\u6B62\u3081\u308B\u529B\u306B\u3082\u306A\u308B\u3002\n\u305D\u308C\u3059\u3089\u306A\u304B\u3063\u305F\u306A\u3089\u3001\u3082\u3046\u7D42\u308F\u3063\u3066\u305F\u306E\u3088\u3002"
  - isPlayer: 1
    message: "\u3067\u3082\u2026\u2026\u9ED9\u3063\u3066\u3044\u305F\u3063\u3066\u3053\u3068\u306F\u3001\u8CAC\u3081\u305F\u304F\u306A\u304B\u3063\u305F\u3093\u3058\u3083\u306A\u3044\u304B\u306A\u3002"
  - isPlayer: 1
    message: "\u201C\u4FE1\u3058\u305F\u304B\u3063\u305F\u201D\u304B\u3089\u3001\u8A00\u8449\u3092\u98F2\u307F\u8FBC\u3093\u3060\u3002\n\u305D\u3046\u3044\u3046\u3053\u3068\u3082\u3042\u308B\u3068\u601D\u3046\u3002"
  - isPlayer: 0
    message: "\u305D\u308C\u306F\u3001\u3042\u306A\u305F\u306E\u201C\u3084\u3055\u3057\u3055\u201D\u306D\u3002\n\u3067\u3082\u3001\u3084\u3055\u3057\u3055\u306F\u6642\u306B\u3001\u75DB\u307F\u3092\u898B\u9003\u3059\u3002"
  - isPlayer: 0
    message: "\u79C1\u306F\u2026\u2026\u201C\u58F0\u3092\u4E0A\u3052\u308B\u201D\u3079\u304D\u3060\u3063\u305F\u3068\u601D\u3046\u3002\n\u9ED9\u3063\u3066\u3044\u305F\u304B\u3089\u3001\u4F55\u3082\u5909\u3048\u3089\u308C\u306A\u304B\u3063\u305F\u3002"
  - isPlayer: 1
    message: "\uFF08\u30BB\u30EA\u30AB\u306E\u8A00\u8449\u306F\u51B7\u9759\u3060\u3051\u3069\u3001\u5965\u306B\u71B1\u304C\u3042\u308B\u3002\n\u5F7C\u5973\u306F\u3001\u8AB0\u304B\u306B\u5BFE\u3057\u3066\u3001\u8A00\u3048\u306A\u304B\u3063\u305F\u6012\u308A\u3092\u62B1\u3048\u3066\u3044\u308B\uFF09"
  - isPlayer: 1
    message: "\uFF08\u79C1\u306F\u2026\u2026\u3069\u3046\u5411\u304D\u5408\u3048\u3070\u3044\u3044\uFF1F\n\u3053\u306E\u8A18\u61B6\u306B\u3001\u4F55\u3092\u3076\u3064\u3051\u308B\u3079\u304D\u306A\u3093\u3060\u308D\u3046\uFF09"
