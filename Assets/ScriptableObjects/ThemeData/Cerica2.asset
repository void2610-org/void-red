  m_Script: {fileID: 11500000, guid: e825166e0c2c14bab83629c2b18411fc, type: 3}
  m_Name: Cerica2
  m_EditorClassIdentifier: 
  title: "\u4FE1\u3058\u305F\u7F70"
  description: "\u306A\u305C\u3001\u4EBA\u306F\u4EBA\u3092\u6B3A\u304F\u306E\u304B\u3002\n\u305D\u3046\u601D\u3063\u305F\u6642\u70B9\u3067\u3001\u79C1\u306F\u3059\u3067\u306B\u596A\u308F\u308C\u3066\u3044\u305F\u306E\u3060\u3002\n\n\u904E\u53BB\u306F\u3059\u3079\u3066\u3001\u7121\u306B\u5E30\u3057\u305F\u3002\n\u79C1\u304C\u4FE1\u3058\u3066\u304D\u305F\u3082\u306E\u306F\u3001\u3059\u3079\u3066\u8336\u756A\u3060\u3063\u305F\u3002\n\u865A\u7A7A\u306E\u3088\u3046\u306B\u3001\u5F62\u3060\u3051\u304C\u6B8B\u3063\u3066\u3044\u305F\u3002\n\n\u305D\u3057\u3066\u3001\u3072\u3068\u308A\u79C1\u306F\u3064\u3076\u3084\u3044\u305F\u3002\n\u2014\u2014\u4FE1\u3058\u305F\u79C1\u304C\u3001\u99AC\u9E7F\u3060\u3063\u305F\u3002"
  attributeMultipliers:
    serializedList:
    - key: 0
      value: 1
    - key: 1
      value: 1.2
    - key: 2
      value: 1.2
    - key: 3
      value: 1.5
    - key: 4
      value: 1.1
    - key: 5
      value: 1
  keywords: []
  dialogues:
  - isPlayer: 1
    message: "\u2026\u2026\u4FE1\u3058\u305F\u3053\u3068\u304C\u7F70\u306B\u306A\u308B\u306A\u3093\u3066\u3001\u305D\u3093\u306A\u306E\u3001\u3042\u3093\u307E\u308A\u3060\u3088\u3002"
  - isPlayer: 1
    message: "\u5F7C\u5973\u306F\u304D\u3063\u3068\u3001\u8AB0\u304B\u3092\u4FE1\u3058\u305F\u304B\u3063\u305F\u3060\u3051\u306A\u306E\u306B\u2026\u2026"
  - isPlayer: 1
    message: "\u305D\u308C\u304C\u5168\u90E8\u3001\u8336\u756A\u3060\u3063\u305F\u306A\u3093\u3066\u2026\u2026\n\u3069\u3046\u3057\u3066\u305D\u3093\u306A\u3053\u3068\u304C\u8D77\u304D\u308B\u3093\u3060\u308D\u3046"
  - isPlayer: 0
    message: "\u8D77\u304D\u308B\u308F\u3088\u3002\n\u4FE1\u3058\u308B\u5FC3\u3092\u3001\u90FD\u5408\u3088\u304F\u5229\u7528\u3059\u308B\u4EBA\u9593\u306F\u3044\u308B\u3002"
  - isPlayer: 0
    message: "\u5F7C\u5973\u304C\u51FA\u4F1A\u3063\u305F\u306E\u306F\u3001\u305D\u3046\u3044\u3046\u201C\u8AB0\u304B\u201D\u3002\n\u2026\u2026\u3042\u306E\u30DA\u30C6\u30F3\u5E2B\u307F\u305F\u3044\u306A\u306D"
  - isPlayer: 1
    message: "\u30DA\u30C6\u30F3\u5E2B\u2026\u2026\uFF1F\n\u30BB\u30EA\u30AB\u3001\u8AB0\u306E\u3053\u3068\u2026\u2026\uFF1F"
  - isPlayer: 0
    message: "\u6614\u306E\u8A71\u3088\u3002\n\u4FE1\u3058\u308B\u3053\u3068\u3092\u990C\u306B\u3057\u3066\u3001\u5FC3\u3092\u55B0\u3089\u3046\u3088\u3046\u306A\u4EBA\u9593\u3002\n"
  - isPlayer: 0
    message: "\u5F7C\u5973\u306E\u8A18\u61B6\u3092\u898B\u3066\u3044\u308B\u3068\u3001\u601D\u3044\u51FA\u3059\u306E\u3002\n\u3042\u306E\u76EE\u3001\u3042\u306E\u8A00\u8449\u2026\u2026\u5168\u90E8\u3001\u5618\u3060\u3063\u305F"
  - isPlayer: 1
    message: "\u2026\u2026\u30BB\u30EA\u30AB\u3082\u3001\u4FE1\u3058\u305F\u3053\u3068\u304C\u3042\u308B\u3093\u3060\u306D\u3002\n\u305D\u308C\u304C\u58CA\u3055\u308C\u305F\u6642\u306E\u75DB\u307F\u3063\u3066\u3001\u3069\u3093\u306A\u611F\u3058\u306A\u3093\u3060\u308D\u3046\u3002"
  - isPlayer: 1
    message: "(\u79C1\u306B\u306F\u3001\u307E\u3060\u3061\u3083\u3093\u3068\u308F\u304B\u3089\u306A\u3044\u3051\u3069\u2026\u2026\n\u5F7C\u5973\u306E\u8A00\u8449\u3092\u805E\u3044\u3066\u308B\u3068\u3001\u80F8\u304C\u304E\u3085\u3063\u3066\u306A\u308B)"
  - isPlayer: 0
    message: "\u308F\u304B\u3089\u306A\u304F\u3066\u3044\u3044\u3002\n\u308F\u304B\u3089\u306A\u3044\u65B9\u304C\u3001\u512A\u3057\u3055\u3092\u6301\u3063\u3066\u3044\u3089\u308C\u308B\u3002"
  - isPlayer: 0
    message: "\u3067\u3082\u3001\u5F7C\u5973\u306E\u201C\u4FE1\u3058\u305F\u7F70\u201D\u306F\u3001\u8AB0\u304B\u304C\u898B\u3066\u3044\u306A\u304D\u3083\u3044\u3051\u306A\u3044\u3002\n\u305D\u3046\u3058\u3083\u306A\u304D\u3083\u3001\u307E\u305F\u540C\u3058\u3053\u3068\u304C\u7E70\u308A\u8FD4\u3055\u308C\u308B\u3002"
  - isPlayer: 1
    message: "\u79C1\u3001\u898B\u3066\u3044\u305F\u3044\u3002\n\u5F7C\u5973\u304C\u4FE1\u3058\u305F\u3053\u3068\u3082\u3001\u50B7\u3064\u3044\u305F\u3053\u3068\u3082\u3001\u5168\u90E8\u3002"
  - isPlayer: 1
    message: "\u305D\u308C\u304C\u3001\u5F7C\u5973\u306E\u201C\u771F\u5B9F\u201D\u3060\u3063\u305F\u306A\u3089\u2026\u2026\n\u79C1\u306F\u3001\u305D\u308C\u3092\u5426\u5B9A\u3057\u305F\u304F\u306A\u3044\u3002"
  - isPlayer: 0
    message: "\u2026\u2026\u30D2\u30AB\u30EA\u306F\u3001\u512A\u3057\u3044\u308F\u306D\u3002\n"
  - isPlayer: 0
    message: "\u305D\u306E\u512A\u3057\u3055\u304C\u3001\u5F7C\u5973\u306E\u75DB\u307F\u306B\u89E6\u308C\u305F\u6642\u3001\n\u4F55\u304B\u3092\u5909\u3048\u3089\u308C\u308B\u304B\u3082\u3057\u308C\u306A\u3044\u3002"
  - isPlayer: 0
    message: "\u79C1\u306F\u2026\u2026\u305D\u306E\u77AC\u9593\u3092\u3001\u898B\u5C4A\u3051\u305F\u3044\u3068\u601D\u3046\u3002\n\u5F7C\u5973\u304C\u3001\u3082\u3046\u4E00\u5EA6\u201C\u4FE1\u3058\u308B\u201D\u3053\u3068\u3092\u9078\u3076\u306A\u3089\u3002"
