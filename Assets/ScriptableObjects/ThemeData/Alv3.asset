  keywords:
  - "\u7126\u3052\u8DE1"
  - "\u7A7A\u9593\u306E\u88C2\u50B7"
  - "\u8D66\u3057\u306E\u7070"
  - "\u53EB\u3073\u306E\u6B8B\u97FF"
  - "\u9858\u3044\u306E\u6B8B\u97FF"
  - "\u7948\u308A\u306E\u304B\u305F\u3061"
  - "\u9589\u3058\u3089\u308C\u305F\u4F59\u5730"
  - "\u88C2\u3051\u76EE"
  - "\u5589\u306E\u8ECB\u307F"
  - "\u713C\u3051\u6B8B\u308B\u885D\u52D5"
  - "\u7815\u3051\u305F\u9078\u629E"
  - "\u9078\u3070\u308C\u306A\u304B\u3063\u305F\u8A18\u61B6"
  dialogues:
  - isPlayer: 0
    message: "\u3055\u3066\u3001\u3044\u3088\u3044\u3088\u3067\u3059\u306D\u3002"
  - isPlayer: 0
    message: "\u4ECA\u56DE\u306E\u6A21\u64EC\u30AA\u30FC\u30AF\u30B7\u30E7\u30F3\u3067\u6271\u308F\u308C\u308B\u8A18\u61B6\u306E\u4E2D\u3067\u306F\u3001\u3053\u308C\u304C\u6700\u3082\u201C\u91CD\u307F\u201D\u306E\u3042\u308B\u3082\u306E\u3060\u3068\u601D\u308F\u308C\u307E\u3059\u3002"
  - isPlayer: 0
    message: "\u672C\u6765\u3067\u3042\u308C\u3070\u3001\u6301\u3061\u4E3B\u306E\u904B\u547D\u3092\u5DE6\u53F3\u3059\u308B\u307B\u3069\u306E\u7D14\u5EA6\u3092\u6301\u3063\u305F\n\u4E00\u54C1\u3067\u3059\u3002\u305F\u3060\u3001\u4ECA\u56DE\u306F\u201C\u6A21\u64EC\u201D\u3067\u3059\u304B\u3089\u2014\u2014"
  - isPlayer: 0
    message: "\u8AB0\u304B\u306E\u5FC3\u3092\u672C\u6C17\u3067\u63FA\u3089\u3059\u307B\u3069\u306E\u529B\u306F\u3001\u610F\u56F3\u7684\u306B\u6291\u3048\u3089\u308C\u3066\u3044\u307E\u3059\u3002\n\u305D\u308C\u3067\u3082\u3001\u8A18\u61B6\u3068\u3057\u3066\u306E\u69CB\u9020\u306F\u975E\u5E38\u306B\u6D17\u7DF4\u3055\u308C\u3066\u3044\u3066\u3001\u5B8C\u6210\u5EA6\u306F\u7533\u3057\u5206\u3042\u308A\u307E\u305B\u3093\u3002"
  - isPlayer: 1
    message: "\u2026\u2026\u5B8C\u6210\u5EA6\u3001\u306D\u3002"
  - isPlayer: 1
    message: "\u305F\u3057\u304B\u306B\u3001\u8A00\u8449\u306E\u6D41\u308C\u3082\u3001\u60C5\u666F\u3082\u3001\u3059\u3054\u304F\u6574\u3063\u3066\u308B\u3002\n\u3067\u3082\u3001\u305D\u308C\u3060\u3051\u3058\u3083\u306A\u3044\u6C17\u304C\u3059\u308B\u3002"
  - isPlayer: 1
    message: "\u8AAD\u3093\u3067\u308B\u3068\u3001\u80F8\u304C\u3056\u308F\u3064\u3044\u3066\u3001\u5589\u306E\u5965\u304C\u8A70\u307E\u308B\u3088\u3046\u306A\u6C17\u304C\u3057\u3066\u2026\u2026\n\u3053\u308C\u3001\u672C\u5F53\u306B\u201C\u6A21\u64EC\u201D\u306A\u306E\uFF1F"
  - isPlayer: 0
    message: "\u6A21\u64EC\u3067\u3042\u308B\u3053\u3068\u306B\u5909\u308F\u308A\u306F\u3042\u308A\u307E\u305B\u3093\u3002\n\u3051\u308C\u3069\u3001\u3042\u306A\u305F\u304C\u305D\u3046\u611F\u3058\u308B\u306A\u3089\u3001\u305D\u308C\u306F\u8A18\u61B6\u304C\u3088\u304F\u3067\u304D\u3066\u3044\u308B\u8A3C\u3067\u3059\u3002"
  - isPlayer: 0
    message: "\u3053\u306E\u5834\u3067\u554F\u308F\u308C\u308B\u306E\u306F\u3001\u8A18\u61B6\u306E\u6B63\u3057\u3055\u3067\u3082\u3001\u5B8C\u6210\u5EA6\u3067\u3082\u306A\u3044\u3002\n\u3042\u306A\u305F\u81EA\u8EAB\u304C\u3001\u3069\u308C\u3060\u3051\u305D\u306E\u611F\u60C5\u3092\u8CED\u3051\u3089\u308C\u308B\u304B\u2014\u2014\u305D\u308C\u3060\u3051\u3067\u3059\u3002"
  - isPlayer: 1
    message: "\u2026\u2026\u8CED\u3051\u308B\u3001\u3063\u3066\u2026\u2026\n\u305D\u3093\u306A\u7C21\u5358\u306B\u8A00\u308F\u306A\u3044\u3067\u3002"
  - isPlayer: 1
    message: "\u3053\u308C\u306F\u8AB0\u304B\u304C\u8D66\u305B\u306A\u304F\u3066\u3001\u5FD8\u308C\u3089\u308C\u306A\u304F\u3066\u3001\n\u305D\u308C\u3067\u3082\u58F0\u3092\u51FA\u305D\u3046\u3068\u3057\u3066\u308B\u3001\u305D\u3093\u306A\u8A18\u61B6\u306A\u306E\u306B\u2026\u2026"
  - isPlayer: 1
    message: "\u6A5F\u68B0\u7684\u306B\u8A9E\u3063\u3066\u3044\u3044\u8A18\u61B6\u3058\u3083\u306A\u3044\u3088\u3002\u5C11\u306A\u304F\u3068\u3082\u79C1\u306B\u306F\u3001\n\u3053\u306E\u8A18\u61B6\u306F\u307B\u3093\u3068\u306B\u8AB0\u304B\u304C\u6301\u3064\u60B2\u75DB\u306A\u53EB\u3073\u306B\u898B\u3048\u308B\u308F\u3002"
  - isPlayer: 0
    message: "\u305D\u308C\u306F\u3001\u3042\u306A\u305F\u304C\u3053\u306E\u8A18\u61B6\u306B\u89E6\u308C\u305F\u8A3C\u3067\u3059\u306D\u3002\n\u75DB\u307F\u3092\u62B1\u3048\u3066\u53EB\u3076\u304B\u3001\u72C2\u6C17\u306B\u89E6\u308C\u305F\u3082\u306E\u3092\u5632\u7B11\u3046\u304B\u2014\u2014"
  - isPlayer: 0
    message: "\u3069\u3061\u3089\u3092\u9078\u3076\u304B\u3067\u3001\n\u3042\u306A\u305F\u306E\u7CBE\u795E\u304C\u3069\u3053\u306B\u7ACB\u3063\u3066\u3044\u308B\u304B\u304C\u898B\u3048\u3066\u304D\u307E\u3059\u3002\n"
  - isPlayer: 0
    message: "\u3053\u306E\u5834\u3067\u554F\u308F\u308C\u308B\u306E\u306F\u3001\u8A18\u61B6\u306E\u6B63\u3057\u3055\u3067\u3082\u3001\u5B8C\u6210\u5EA6\u3067\u3082\u3042\u308A\u307E\u305B\u3093\u3002"
  - isPlayer: 1
    message: "\u2026\u2026\u3060\u3063\u305F\u3089\u3001\u79C1\u306F\u3053\u306E\u8A18\u61B6\u306B\u4F55\u3092\u8CED\u3051\u3089\u308C\u308B\u3093\u3060\u308D\u3046\u3002"
  - isPlayer: 1
    message: "\u305F\u3060\u80F8\u304C\u82E6\u3057\u304F\u3066\u3001\u8A00\u8449\u306B\u306A\u3089\u306A\u304F\u3066\u2026\u2026\n\u305D\u308C\u3067\u3082\u3001\u5C4A\u3044\u3066\u307B\u3057\u3044\u3063\u3066\u601D\u3063\u3066\u3057\u307E\u3046\u3002"
  - isPlayer: 1
    message: "\u5272\u308C\u305F\u58F0\u3067\u3082\u3001\u5D29\u308C\u305F\u97F3\u3067\u3082\u3001\u8AB0\u304B\u306E\u4E2D\u306B\u6B8B\u3063\u3066\u307B\u3057\u3044\u3063\u3066\u3002"
  - isPlayer: 0
    message: "\u305D\u306E\u201C\u601D\u3063\u3066\u3057\u307E\u3046\u201D\u304C\u3001\u3059\u3067\u306B\u8CED\u3051\u306E\u59CB\u307E\u308A\u3067\u3059\u3002"
  - isPlayer: 0
    message: "\u6A21\u64EC\u3067\u3042\u3063\u3066\u3082\u3001\u3042\u306A\u305F\u306E\u63FA\u308C\u306F\u672C\u7269\u3067\u3059\u304B\u3089\u3002\n\u8A18\u61B6\u306F\u3001\u89E6\u308C\u305F\u8005\u306E\u304B\u305F\u3061\u3092\u6620\u3059\u93E1\u306E\u3088\u3046\u306A\u3082\u306E\u3002"
  - isPlayer: 0
    message: "\u3042\u306A\u305F\u304C\u305D\u306E\u75DB\u307F\u306B\u7ACB\u3061\u6B62\u307E\u308B\u306A\u3089\u2014\u2014\n\u305D\u308C\u3082\u307E\u305F\u3001\u7CBE\u795E\u306E\u3072\u3068\u3064\u306E\u5F62\u3067\u3059\u3002"
