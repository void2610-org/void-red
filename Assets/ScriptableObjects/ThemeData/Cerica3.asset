  keywords:
  - "\u308F\u305A\u304B\u306A\u5149"
  - "\u8A17\u3055\u308C\u305F\u6E29\u5EA6"
  - "\u920D\u304F\u306A\u308B\u75DB\u307F"
  - "\u9759\u304B\u306B\u606F\u3065\u304F"
  - "\u3055\u307E\u3088\u3046\u885D\u52D5"
  dialogues:
  - isPlayer: 0
    message: "\u2026\u2026"
  - isPlayer: 0
    message: "\u2026\u2026\u3069\u3046\u3057\u3066\u2026\u2026"
  - isPlayer: 0
    message: "\u306A\u3093\u3067\u2026\u2026\u3053\u3093\u306A\u306E\u2026\u2026"
  - isPlayer: 0
    message: "\u3084\u3081\u3066\u3088\u2026\u2026\u3053\u3093\u306A\u306E\u2026\u2026\u898B\u305B\u306A\u3044\u3067\u2026\u2026"
  - isPlayer: 0
    message: "\u2026\u2026\u3053\u3093\u306A\u306E\u2026\u2026\u79C1\u2026\u2026"
  - isPlayer: 1
    message: "\u30BB\u30EA\u30AB\u2026\u2026\u5927\u4E08\u592B\uFF1F\n\u4ECA\u306E\u8A18\u61B6\u3001\u3059\u3054\u304F\u2026\u2026\u82E6\u3057\u305D\u3046\u3060\u3063\u305F\u3002"
  - isPlayer: 1
    message: "\u4F55\u304B\u3001\u3042\u306A\u305F\u306E\u4E2D\u306E\u672C\u97F3\u306B\u89E6\u308C\u3066\u3057\u307E\u3063\u305F\u3088\u3046\u306A\u2026\u2026"
  - isPlayer: 0
    message: "\u82E6\u3057\u3044\u306B\u6C7A\u307E\u3063\u3066\u308B\u2026\u2026\n\u89E6\u308C\u305F\u304F\u306A\u304B\u3063\u305F\u306E\u306B\u3001\u89E6\u308C\u3066\u3057\u307E\u3063\u305F\u3002"
  - isPlayer: 0
    message: "\u58CA\u3057\u305F\u304B\u3063\u305F\u306E\u306B\u3001\u58CA\u3057\u304D\u308C\u306A\u304B\u3063\u305F\u3002\n\u305D\u306E\u611F\u89E6\u304C\u3001\u4ECA\u3082\u307E\u3060\u6B8B\u3063\u3066\u308B\u2026\u2026"
  - isPlayer: 0
    message: "\u2026\u2026\u306A\u3093\u3067\u3001\u3053\u3093\u306A\u306B\u3082\u3001\u79C1\u306E\u4E2D\u3067\u6E26\u5DFB\u304F\u306E\u2026"
  - isPlayer: 1
    message: "\u79C1\u3082\u2026\u2026\u898B\u3066\u3044\u3066\u3001\u80F8\u304C\u3056\u308F\u3064\u3044\u305F\u3002\n\u8A00\u8449\u304C\u306A\u3044\u306E\u306B\u3001\u4F55\u304B\u304C\u4F1D\u308F\u3063\u3066\u304F\u308B\u3002"
  - isPlayer: 1
    message: "\u512A\u3057\u3055\u306A\u306E\u304B\u3001\u8AE6\u3081\u306A\u306E\u304B\u2026\u2026\n\u3067\u3082\u3001\u78BA\u304B\u306B\u201C\u6E29\u5EA6\u201D\u304C\u3042\u3063\u305F\u3002"
  - isPlayer: 1
    message: "\u305D\u308C\u304C\u3001\u4ECA\u3082\u79C1\u306E\u5965\u5E95\u3067\u8108\u3092\u6253\u3063\u3066\u308B\u6C17\u304C\u3057\u3066\u2026\u2026\u6016\u304B\u3063\u305F\u3002"
  - isPlayer: 0
    message: "\u6016\u3044\uFF1F\u3042\u306A\u305F\u304C\uFF1F\n\u4F55\u3082\u77E5\u3089\u306A\u3044\u304F\u305B\u306B\u3001\u305D\u3093\u306A\u3075\u3046\u306B\u8A00\u308F\u306A\u3044\u3067\u3002"
  - isPlayer: 0
    message: "\u79C1\u304C\u4F55\u3092\u62B1\u3048\u3066\u308B\u304B\u3082\u77E5\u3089\u306A\u3044\u306E\u306B\u2026\u2026\n\u3042\u306A\u305F\u306B\u3060\u3051\u306F\u5206\u304B\u3063\u3066\u6B32\u3057\u304F\u306A\u3044\u308F\u3002"
  - isPlayer: 0
    message: "\u540C\u60C5\u306A\u3093\u3066\u3055\u308C\u305F\u304F\u306A\u304B\u3063\u305F\u2026\u2026"
  - isPlayer: 1
    message: "\u540C\u60C5\u3058\u3083\u306A\u3044\u3088\u3002\n\u79C1\u3082\u3001\u3053\u306E\u8A18\u61B6\u306B\u89E6\u308C\u3066\u3057\u307E\u3063\u305F\u3002"
  - isPlayer: 1
    message: "\u5F7C\u5973\u304C\u4F55\u3092\u611F\u3058\u3066\u3044\u305F\u306E\u304B\u3001\n\u305D\u306E\u201C\u91CD\u3055\u201D\u3092\u3001\u5C11\u3057\u3067\u3082\u77E5\u308A\u305F\u304F\u306A\u3063\u305F\u3002"
  - isPlayer: 1
    message: "\u3060\u304B\u3089\u3001\u79C1\u3082\u672D\u306B\u8FBC\u3081\u308B\u3002\n\u3053\u306E\u6C17\u6301\u3061\u3092\u3001\u5168\u90E8"
  - isPlayer: 0
    message: "\u2026\u2026\u30D2\u30AB\u30EA\u307E\u3067\u3001\u305D\u3093\u306A\u3053\u3068\u8A00\u3046\u306E\u3002\n\u3042\u306A\u305F\u304C\u62B1\u3048\u3066\u3066\u3082\u3044\u3044\u3082\u306E\u3067\u306F\u306A\u3044\u306E\u306B\u3002"
  - isPlayer: 0
    message: "\u305D\u308C\u3067\u3082\u3001\u672D\u306B\u8FBC\u3081\u308B\u3063\u3066\u8A00\u3046\u306E\u306D\u3002\n\u2026\u2026\u305A\u308B\u3044\u308F\u3002"
  - isPlayer: 0
    message: "\u305D\u3093\u306A\u3075\u3046\u306B\u8A00\u308F\u308C\u305F\u3089\u3001\n\u79C1\u3082\u3001\u9003\u3052\u3089\u308C\u306A\u304F\u306A\u308B\u3058\u3083\u306A\u3044\u3002"
  - isPlayer: 1
    message: "\u9003\u3052\u306A\u304F\u3066\u3044\u3044\u3002"
  - isPlayer: 1
    message: "\u3067\u3082\u3001\u7ACB\u3061\u5C3D\u304F\u3059\u3060\u3051\u3058\u3083\u306A\u304F\u3066\u3001\n\u305D\u306E\u624B\u306B\u6B8B\u3063\u305F\u6E29\u5EA6\u3092\u3001\u672D\u306B\u8FBC\u3081\u3066\u3088\u3002"
  - isPlayer: 1
    message: "\u305D\u308C\u304C\u3001\u3042\u306A\u305F\u306E\u201C\u3042\u308A\u3063\u305F\u3051\u201D\u306A\u3089\u2014\u2014\n\u79C1\u3082\u3001\u6B63\u9762\u304B\u3089\u8FBC\u3081\u308B\u304B\u3089\u3002"
  - isPlayer: 0
    message: "\u2026\u2026\u308F\u304B\u3063\u305F\u3002\n\u79C1\u306E\u201C\u3042\u308A\u3063\u305F\u3051\u201D\u306A\u3093\u3066\u3001\u3082\u3046\u6B8B\u3063\u3066\u306A\u3044\u3068\u601D\u3063\u3066\u305F\u3002"
  - isPlayer: 0
    message: "\u3067\u3082\u3001\u3042\u306A\u305F\u304C\u76EE\u306E\u524D\u306B\u3044\u308B\u306A\u3089\u2026\u2026\n\u5C11\u3057\u3060\u3051\u3001\u4FE1\u3058\u3066\u307F\u3066\u3082\u3044\u3044\u304B\u3082\u3057\u308C\u306A\u3044\u3002"
