%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cdcfb148a1da14a798321691be66286c, type: 3}
  m_Name: Alv
  m_EditorClassIdentifier:
  responses:
  - targetChoice: 0
    dialogueText: "ふん、私を挑発するつもりか？面白い。だが、その程度では動じないぞ。"
    effect:
      actionType: 1
      resourceChangeAmount: -1
  - targetChoice: 1
    dialogueText: "...そうか、お前も似たような経験があるのか。少しだけ、気が楽になった。"
    effect:
      actionType: 1
      resourceChangeAmount: 2
  - targetChoice: 2
    dialogueText: "なるほど、理にかなっている。お前の言葉には一理あるな。"
    effect:
      actionType: 1
      resourceChangeAmount: 1
  - targetChoice: 3
    dialogueText: "黙っているのか...まあいい。言葉がなくとも、意図は伝わる。"
    effect:
      actionType: 0
      resourceChangeAmount: 0
  initiations:
  - triggerChoice: 0
    enemyDialogueText: "お前の度胸は認めよう。だが、この勝負、本気で勝てると思っているのか？"
    playerOptions:
    - optionText: "当たり前でしょ。舐めないで"
      resultText: "その自信、嫌いじゃない。"
      effect:
        actionType: 1
        resourceChangeAmount: -1
    - optionText: "勝つわよ。絶対にね"
      resultText: "ほう、面白い女だ。"
      effect:
        actionType: 0
        resourceChangeAmount: 0
    - optionText: "あんたこそ、油断してると痛い目見るわよ"
      resultText: "忠告痛み入る。"
      effect:
        actionType: 1
        resourceChangeAmount: 1
  - triggerChoice: 1
    enemyDialogueText: "お前には...何か大切なものがあるのだろう？私にもかつてあった。"
    playerOptions:
    - optionText: "あるわよ。だから負けられないの"
      resultText: "そうか...守れるといいな。"
      effect:
        actionType: 1
        resourceChangeAmount: 1
    - optionText: "失ったものは...取り戻すしかないでしょ"
      resultText: "...同感だ。"
      effect:
        actionType: 1
        resourceChangeAmount: 2
    - optionText: "過去の話はいいわ。今に集中して"
      resultText: "簡単に言ってくれる。"
      effect:
        actionType: 1
        resourceChangeAmount: -1
  - triggerChoice: 2
    enemyDialogueText: "お前の言葉には説得力がある。だが、行動で示してもらおうか。"
    playerOptions:
    - optionText: "見てれば分かるわ"
      resultText: "楽しみにしている。"
      effect:
        actionType: 0
        resourceChangeAmount: 0
    - optionText: "口より先に手が動くタイプなの"
      resultText: "それでこそだ。"
      effect:
        actionType: 1
        resourceChangeAmount: 1
    - optionText: "まずはあんたが見せなさいよ"
      resultText: "ふっ、生意気だな。"
      effect:
        actionType: 1
        resourceChangeAmount: -1
  - triggerChoice: 3
    enemyDialogueText: "沈黙か...言葉を選んでいるのか、それとも何も考えていないのか。"
    playerOptions:
    - optionText: "考えてるに決まってるでしょ"
      resultText: "なら、その考えを聞かせろ。"
      effect:
        actionType: 0
        resourceChangeAmount: 0
    - optionText: "言葉なんていらないわ"
      resultText: "...そういう奴もいるか。"
      effect:
        actionType: 1
        resourceChangeAmount: 1
    - optionText: "あんたに話すことなんてないわ"
      resultText: "冷たいな。"
      effect:
        actionType: 1
        resourceChangeAmount: -1
